IF
	!InMyArea(Player1)
	!InMyArea(Player2)
	!InMyArea(Player3)
	!InMyArea(Player4)
	!InMyArea(Player5)
	!InMyArea(Player6)
THEN
	RESPONSE #100
		DestroySelf()
END

IF
	NumCreatureGT("LZBGAI",1)  // No such index
THEN
	RESPONSE #100
		DestroySelf()
END

IF
	Global("LZBGAICombatCheck","GLOBAL",1)
	Global("LZBGAIInCombat","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("LZBGAIInCombat","LOCALS",1)
		Continue()
END

IF
	Global("LZBGAICombatCheck","GLOBAL",0)
	Global("LZBGAIInCombat","LOCALS",1)
THEN
	RESPONSE #100
		SetGlobal("LZBGAIInCombat","LOCALS",0)
		DestroySelf()
END

IF
	Global("LZBGAIActive","GLOBAL",1)
THEN
	RESPONSE #100
		DestroySelf()
END

IF
	Detect([GOODCUTOFF])
	Detect([EVILCUTOFF])
	!Range([EVILCUTOFF],10)
	ActionListEmpty()
THEN
	RESPONSE #100
		JumpToObject([EVILCUTOFF])
		Continue()
END

IF
	See([EVILCUTOFF])
	!Gender(LastSeenBy(Myself),SUMMONED)
	!TriggerOverride(LastSeenBy(Myself),Detect([GOODCUTOFF]))
	!StateCheck(LastSeenBy(Myself),STATE_DISABLED)
	InMyArea(Player1)
	CheckStat(Player1,0,SANCTUARY)
	!StateCheck(Player1,STATE_REALLY_DEAD)
	!StateCheck(Player1,STATE_NOT_APPROACHABLE)
	!GlobalTimerNotExpired("LZAIJumpdelay","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("LZAIJumpdelay","LOCALS",ONE_ROUND)
		ActionOverride(LastSeenBy(Myself),MoveToObject(Player1))
		Continue()
END

IF
	See(TenthNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
	See(NinthNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
	See(EighthNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
	See(SeventhNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
	See(SixthNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
	See(FifthNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
	See(FourthNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
	See(ThirdNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
	See(SecondNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
	See([EVILCUTOFF.0.0.0.0.SUMMONED])
	ActionListEmpty()
	!GlobalTimerNotExpired("LZAIJumpdelay","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("LZAIJumpdelay","LOCALS",FIVE_ROUNDS)
		JumpToObject(TenthNearest([EVILCUTOFF.0.0.0.0.SUMMONED]))
		Continue()
END

IF
	See([EVILCUTOFF.0.DEMONIC])
	TriggerOverride(LastSeenBy(Myself),Global("LZAIDemonicEff","LOCALS",0))
THEN
	RESPONSE #100
		ActionOverride(LastSeenBy(Myself),SetGlobal("LZAIDemonicEff","LOCALS",1))
		CreateVisualEffectObject("SPSNRAYI",LastSeenBy(Myself))
		ReallyForceSpellRES("LZAISP12",LastSeenBy(Myself))  // 荆棘皮环甲+6
END

