IF
	See([EVILCUTOFF.0.0.MAGE_ALL])
	!Gender(LastSeenBy(Myself),SUMMONED)
	TriggerOverride(LastSeenBy(Myself),Global("LZAIMageSC","LOCALS",0))
	!TriggerOverride(LastSeenBy(Myself),GlobalTimerNotExpired("LZAICastdelay","LOCALS"))
	TriggerOverride(LastSeenBy(Myself),Range(NearestEnemyOf(Myself),6))
	!HasItem("BLAKBLAD",LastSeenBy(Myself))  // 毁灭魔剑
	!HasItem("CDMINDFL",LastSeenBy(Myself))  // 攻击
	!HasItem("CDGOLIRO",LastSeenBy(Myself))  // 攻击
	!StateCheck(LastSeenBy(Myself),STATE_DISABLED_CASTING)
	CheckStat(LastSeenBy(Myself),0,SANCTUARY)
	CheckStat(LastSeenBy(Myself),0,AURACLEANSING)
	ObjectActionListEmpty(LastSeenBy(Myself))
	RandomNumGT(3,1)
THEN
	RESPONSE #50
		ActionOverride(LastSeenBy(Myself),SetGlobal("LZAIMageSC","LOCALS",1))
		ActionOverride(LastSeenBy(Myself),SetGlobalTimer("LZAICastdelay","LOCALS",THREE_ROUNDS))
		ActionOverride(LastSeenBy(Myself),CreateVisualEffectObject("SPSNRAYI",Myself))
		ActionOverride(LastSeenBy(Myself),ForceSpellRES("LZSCCOB1",Myself))
		ActionOverride(LastSeenBy(Myself),AttackOneRound(NearestEnemyOf(Myself)))
		ActionOverride(LastSeenBy(Myself),AttackOneRound(NearestEnemyOf(Myself)))
		ActionOverride(LastSeenBy(Myself),AttackOneRound(NearestEnemyOf(Myself)))
	RESPONSE #50
		ActionOverride(LastSeenBy(Myself),SetGlobal("LZAIMageSC","LOCALS",1))
		ActionOverride(LastSeenBy(Myself),SetGlobalTimer("LZAICastdelay","LOCALS",THREE_ROUNDS))
		ActionOverride(LastSeenBy(Myself),CreateVisualEffectObject("SPSNRAYI",Myself))
		ActionOverride(LastSeenBy(Myself),ForceSpellRES("LZSCCOB2",Myself))
		ActionOverride(LastSeenBy(Myself),AttackOneRound(NearestEnemyOf(Myself)))
		ActionOverride(LastSeenBy(Myself),AttackOneRound(NearestEnemyOf(Myself)))
		ActionOverride(LastSeenBy(Myself),AttackOneRound(NearestEnemyOf(Myself)))
END

