	TriggerOverride(LastSeenBy(Myself),Global("LZAINotMageCEff","LOCALS",0))
THEN
	RESPONSE #15
		ActionOverride(LastSeenBy(Myself),SetGlobal("LZAINotMageCEff","LOCALS",1))
		CreateVisualEffectObject("SPSNRAYI",LastSeenBy(Myself))
		ReallyForceSpellRES("LZAISP15",LastSeenBy(Myself))  // 快速治疗
		ReallyForceSpellRES("LZAISP07",LastSeenBy(Myself))  // 火牙+4
		ReallyForceSpellRES("LZAISP01",LastSeenBy(Myself))  // 天圣怒火+3
	RESPONSE #15
		ActionOverride(LastSeenBy(Myself),SetGlobal("LZAINotMageCEff","LOCALS",1))
		CreateVisualEffectObject("SPSNRAYI",LastSeenBy(Myself))
		ReallyForceSpellRES("LZAISP15",LastSeenBy(Myself))  // 快速治疗
		ReallyForceSpellRES("LZAISP07",LastSeenBy(Myself))  // 火牙+4
		ReallyForceSpellRES("LZAISP02",LastSeenBy(Myself))  // 岁月连枷+3
	RESPONSE #20
		ActionOverride(LastSeenBy(Myself),SetGlobal("LZAINotMageCEff","LOCALS",1))
		CreateVisualEffectObject("SPSNRAYI",LastSeenBy(Myself))
		ReallyForceSpellRES("LZAISP15",LastSeenBy(Myself))  // 快速治疗
		ReallyForceSpellRES("LZAISP07",LastSeenBy(Myself))  // 火牙+4
		ReallyForceSpellRES("LZAISP06",LastSeenBy(Myself))  // 卡索弥尔+5
	RESPONSE #50
		ActionOverride(LastSeenBy(Myself),SetGlobal("LZAINotMageCEff","LOCALS",1))
		Continue()
END

