	!Gender(LastSeenBy(Myself),SUMMONED)
	TriggerOverride(LastSeenBy(Myself),GlobalLT("LZAIMCowSkill","LOCALS",1))
	!TriggerOverride(LastSeenBy(Myself),GlobalTimerNotExpired("LZAICastdelay","LOCALS"))
	TriggerOverride(LastSeenBy(Myself),Range(NearestEnemyOf(Myself),30))
	TriggerOverride(LastSeenBy(Myself),CheckStatLT(NearestEnemyOf(Myself),90,RESISTCRUSHING))
	!StateCheck(LastSeenBy(Myself),STATE_DISABLED_CASTING)
	CheckStat(LastSeenBy(Myself),0,SANCTUARY)
	CheckStat(LastSeenBy(Myself),0,AURACLEANSING)
	ObjectActionListEmpty(LastSeenBy(Myself))
THEN
	RESPONSE #30
		ActionOverride(LastSeenBy(Myself),IncrementGlobal("LZAIMCowSkill","LOCALS",1))
		ActionOverride(LastSeenBy(Myself),SetGlobalTimer("LZAICastdelay","LOCALS",ONE_ROUND))
		ActionOverride(LastSeenBy(Myself),CreateVisualEffectObject("SPSNRAYI",Myself))
		ActionOverride(LastSeenBy(Myself),ForceSpellRES("LZWI299",NearestEnemyOf(Myself)))  // 召唤乳牛
	RESPONSE #70
		Continue()
END

