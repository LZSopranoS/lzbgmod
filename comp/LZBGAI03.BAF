	!Gender(LastSeenBy(Myself),SUMMONED)
	OR(5)
		Class(LastSeenBy(Myself),MAGE)
		Class(LastSeenBy(Myself),FIGHTER_MAGE)
		Class(LastSeenBy(Myself),MAGE_THIEF)
		Class(LastSeenBy(Myself),FIGHTER_MAGE_THIEF)
		Class(LastSeenBy(Myself),BARD_ALL)
	TriggerOverride(LastSeenBy(Myself),GlobalLT("LZAIMageSkillOne","LOCALS",1))
	!TriggerOverride(LastSeenBy(Myself),GlobalTimerNotExpired("LZAICastdelay","LOCALS"))
	TriggerOverride(LastSeenBy(Myself),Range(NearestEnemyOf(Myself),30))
	!TriggerOverride(LastSeenBy(Myself),HasBounceEffects(NearestEnemyOf(Myself)))
	!StateCheck(LastSeenBy(Myself),STATE_DISABLED_CASTING)
	CheckStat(LastSeenBy(Myself),0,AURACLEANSING)
	ObjectActionListEmpty(LastSeenBy(Myself))
THEN
	RESPONSE #100
		ActionOverride(LastSeenBy(Myself),IncrementGlobal("LZAIMageSkillOne","LOCALS",1))
		ActionOverride(LastSeenBy(Myself),SetGlobalTimer("LZAICastdelay","LOCALS",TWO_ROUNDS))
		ActionOverride(LastSeenBy(Myself),CreateVisualEffectObject("SPSNRAYI",Myself))
		ActionOverride(LastSeenBy(Myself),DisplayString(Myself,8635))  // 次级定序术启动
		ActionOverride(LastSeenBy(Myself),ReallyForceSpellRES("SPWI106",NearestEnemyOf(Myself)))  // 目盲
		ActionOverride(LastSeenBy(Myself),ReallyForceSpellRES("SPWI221",NearestEnemyOf(Myself)))  // 衰弱射线
	RESPONSE #100
		ActionOverride(LastSeenBy(Myself),IncrementGlobal("LZAIMageSkillOne","LOCALS",1))
		ActionOverride(LastSeenBy(Myself),SetGlobalTimer("LZAICastdelay","LOCALS",TWO_ROUNDS))
		ActionOverride(LastSeenBy(Myself),CreateVisualEffectObject("SPSNRAYI",Myself))
		ActionOverride(LastSeenBy(Myself),DisplayString(Myself,8635))  // 次级定序术启动
		ActionOverride(LastSeenBy(Myself),ReallyForceSpellRES("SPWI211",NearestEnemyOf(Myself)))  // 马友夫强酸箭
		ActionOverride(LastSeenBy(Myself),ReallyForceSpellRES("SPWI211",NearestEnemyOf(Myself)))  // 马友夫强酸箭
	RESPONSE #100
		ActionOverride(LastSeenBy(Myself),IncrementGlobal("LZAIMageSkillOne","LOCALS",1))
		ActionOverride(LastSeenBy(Myself),SetGlobalTimer("LZAICastdelay","LOCALS",TWO_ROUNDS))
		ActionOverride(LastSeenBy(Myself),CreateVisualEffectObject("SPSNRAYI",Myself))
		ActionOverride(LastSeenBy(Myself),DisplayString(Myself,8635))  // 次级定序术启动
		ActionOverride(LastSeenBy(Myself),ReallyForceSpellRES("SPWI118",NearestEnemyOf(Myself)))  // 五彩球
		ActionOverride(LastSeenBy(Myself),ReallyForceSpellRES("SPWI118",NearestEnemyOf(Myself)))  // 五彩球
