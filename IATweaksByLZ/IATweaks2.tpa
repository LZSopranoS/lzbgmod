//铁砧兼容性调整+规则性调整(根据铁砧规则把等级上限从40级扩展到50级，调整的安装文件包括经验、法术位、豁免、命中等，解除铁砧对许愿术出双倍时停高捷的屏蔽)

ACTION_IF (GAME_IS ~eet~) THEN BEGIN

  COPY ~ImprovedAnvil/Setup-ImprovedAnvil.tp2~ ~ImprovedAnvil/Setup-ImprovedAnvil.tp2~
    REPLACE_TEXTUALLY ~bg2ee~ ~bg2ee eet~
  BUT_ONLY

  COPY ~lzbgmod/IATweaksByLZ/resources/creatures/vanilla/imoen10.cre~   ~ImprovedAnvil/resources/creatures/vanilla~      //EET版SOA开局要修改这个，否则卡住，BG2EE则不用 

// 列表
ACTION_DEFINE_ARRAY mod_directory_list BEGIN
    ~ImprovedAnvil/~
	
	~ImprovedAnvil/lib/areas~ ~ImprovedAnvil/lib/core~ ~ImprovedAnvil/lib/creatures~ ~ImprovedAnvil/lib/dialogues~
	~ImprovedAnvil/lib/effects~ ~ImprovedAnvil/lib/items~ ~ImprovedAnvil/lib/kits~ ~ImprovedAnvil/lib/scripts~
	~ImprovedAnvil/lib/spells~ ~ImprovedAnvil/lib/stores~ ~ImprovedAnvil/lib/tpa~
	//~ImprovedAnvil/lib/tables~
	
	~ImprovedAnvil/resources/dlg~ ~ImprovedAnvil/resources/intermediate~
	
	~ImprovedAnvil/scripts/areas~ ~ImprovedAnvil/scripts/beholders~ ~ImprovedAnvil/scripts/clerics~ ~ImprovedAnvil/scripts/common~
	~ImprovedAnvil/scripts/cutscenes~ ~ImprovedAnvil/scripts/demons~ ~ImprovedAnvil/scripts/dragons~
	
	~ImprovedAnvil/scripts/encounters/bridge~ ~ImprovedAnvil/scripts/encounters/brynnlaw~ ~ImprovedAnvil/scripts/encounters/dearnise~ ~ImprovedAnvil/scripts/encounters/docks~
	~ImprovedAnvil/scripts/encounters/druid_grove~ ~ImprovedAnvil/scripts/encounters/druid_quests~ ~ImprovedAnvil/scripts/encounters/firkraag_dungeon~ ~ImprovedAnvil/scripts/encounters/forest_of_myr~
	~ImprovedAnvil/scripts/encounters/forest_of_tethir~ ~ImprovedAnvil/scripts/encounters/graveyard~ ~ImprovedAnvil/scripts/encounters/hell~ ~ImprovedAnvil/scripts/encounters/irenicus_dungeon~
	~ImprovedAnvil/scripts/encounters/oasis~ ~ImprovedAnvil/scripts/encounters/planar_prison~ ~ImprovedAnvil/scripts/encounters/planar_sphere~ ~ImprovedAnvil/scripts/encounters/pocket_plane~
	~ImprovedAnvil/scripts/encounters/random~ ~ImprovedAnvil/scripts/encounters/saradush~ ~ImprovedAnvil/scripts/encounters/sendai_enclave~ ~ImprovedAnvil/scripts/encounters/slums~
	~ImprovedAnvil/scripts/encounters/small_teeth_pass~ ~ImprovedAnvil/scripts/encounters/spellhold~ ~ImprovedAnvil/scripts/encounters/suldanesselar~ ~ImprovedAnvil/scripts/encounters/temple~
	~ImprovedAnvil/scripts/encounters/temple_ruins~ ~ImprovedAnvil/scripts/encounters/the_four~ ~ImprovedAnvil/scripts/encounters/throne_of_bhaal~ ~ImprovedAnvil/scripts/encounters/trademeet~
	~ImprovedAnvil/scripts/encounters/umar_hills~ ~ImprovedAnvil/scripts/encounters/underdark~ ~ImprovedAnvil/scripts/encounters/vagrant_quests~ ~ImprovedAnvil/scripts/encounters/watchers_keep~
	~ImprovedAnvil/scripts/encounters/waukeen_promenade~ ~ImprovedAnvil/scripts/encounters/yaga_shura_keep~
	
	~ImprovedAnvil/scripts/genie~ ~ImprovedAnvil/scripts/golems~ ~ImprovedAnvil/scripts/liches~ ~ImprovedAnvil/scripts/lycanthropes~
	~ImprovedAnvil/scripts/mages~ ~ImprovedAnvil/scripts/misc~ ~ImprovedAnvil/scripts/monsters~ ~ImprovedAnvil/scripts/niether~
	~ImprovedAnvil/scripts/npc~ ~ImprovedAnvil/scripts/patches~ ~ImprovedAnvil/scripts/rakshasa~ ~ImprovedAnvil/scripts/spiders~
	~ImprovedAnvil/scripts/transitions~ ~ImprovedAnvil/scripts/undead~
END

ACTION_DEFINE_ARRAY extension_list BEGIN
    ~baf~
    ~d~
    ~tp2~
    ~tpa~
	~tph~
	~tpp~
END

ACTION_PHP_EACH mod_directory_list AS index1 => mod_dir BEGIN

    //PRINT ~        正在处理的目录: %mod_dir%~

    ACTION_PHP_EACH extension_list AS index2 => ext BEGIN

        // 根据mod_directory_list，进入对应文件夹找后缀extension_list文件
        ACTION_BASH_FOR ~%mod_dir%~ EVALUATE_REGEXP ~^.+\.%ext%$~ BEGIN
            
			// 每个新文件开始时，强制将全局计数器清零，掐断跨文件污染
            OUTER_SET match_count = 0

            //注意：下面这句判断可以去掉，加上是为了使weidu窗口运行时更干净，只显示那些改过的。
            // 匹配任意"CHAPTER"加,
            ACTION_IF FILE_CONTAINS_EVALUATED (~%BASH_FOR_FILESPEC%~ ~"CHAPTER"[ %TAB%]*,~) BEGIN

                // COPY - 纯读入内存，不污染硬盘
                COPY - ~%BASH_FOR_FILESPEC%~ ~.../eet_temp_patch~
		  
                    // 防止IncrementGlobal("CHAPTER",GLOBAL,1)这类被误改
                    REPLACE_TEXTUALLY ~IncrementGlobal~ ~IncrementReplaceMe~
    
                    // 匹配SetGlobal, Global, GlobalGT, GlobalLT, SG, G, GGT, GLT。例： %MATCH1% = Global("CHAPTER","GLOBAL",   %MATCH2% = 2（经过转换后为%eet_chapter%即2+12）   %MATCH3% = )
                    REPLACE_EVALUATE CASE_INSENSITIVE ~\([A-Za-z]*G[A-Za-z]*([ %TAB%]*"CHAPTER"[ %TAB%]*,?[ %TAB%]*"?G?L?O?B?A?L?"?[ %TAB%]*,[ %TAB%]*\)\([0-9]+\)\([ %TAB%]*)\)~ BEGIN
        
		                // 三元运算符 ?   是整数执行MATCH2 + 12，否则不变
                        SET eet_chapter = IS_AN_INT MATCH2 ? (MATCH2 + 12) : MATCH2
        
                        // 仅在真正触发章节转换时，累计匹配次数
                        SET match_count += 1
        
                    END ~%MATCH1%%eet_chapter%%MATCH3%~ 
    
	                // 还原防御改名
                    REPLACE_TEXTUALLY ~IncrementReplaceMe~ ~IncrementGlobal~
					
                BUT_ONLY
				
                // 只有当前文件在内存里确实被改变过，才写入硬盘
                ACTION_IF (match_count > 0) BEGIN
				
                    // 转换成功打印日志
                    PRINT ~    --> 发现文件 (%ext%) 且成功转换 [%match_count% 处] 章节: %BASH_FOR_FILESPEC%~
    
                    // 把内存里改动过的文件写回硬盘
                    COPY ~.../eet_temp_patch~ ~%BASH_FOR_FILESPEC%~
                END
            END
        END
    END
END

END

COPY ~lzbgmod/IATweaksByLZ/lib/core/ids.tph~   ~ImprovedAnvil/lib/core~         //一些规则修改由替换改插入

COPY ~lzbgmod/IATweaksByLZ/lib/core/2da.tph~   ~ImprovedAnvil/lib/core~         //铁砧屏蔽了许愿出双倍时停高捷，修改后解除，下面SPAWNGRP.2DA相关修改调到这里

