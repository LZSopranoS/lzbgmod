//CDTWEAKS 6(改)
ACTION_CLEAR_ARRAY  cd_start_areas

ACTION_DEFINE_ASSOCIATIVE_ARRAY cd_start_areas BEGIN
    //startare => 0
    startbp  => 0
END

ACTION_IF FILE_EXISTS_IN_GAME ~campaign.2da~ THEN BEGIN

    COPY_EXISTING ~campaign.2da~ ~override~
        COUNT_2DA_COLS col_num
        COUNT_2DA_ROWS (col_num - 1) row_num
			FOR (index = 1 ; index < row_num ; ++index) BEGIN // start at 1 to skip header row
				READ_2DA_ENTRY index 13 13 file
				DEFINE_ASSOCIATIVE_ARRAY cd_start_areas BEGIN "%file%" => 0 END
			END
    BUT_ONLY
END

// for EE
ACTION_PHP_EACH cd_start_areas AS file => val BEGIN

    //PRINT ~patching campaign file %file%.2da~

    //ACTION_IF FILE_EXISTS_IN_GAME ~%file%.2da~ THEN BEGIN
	// 加上黑名单过滤，如果是 startare 则直接跳过不显示、不修改
    ACTION_IF FILE_EXISTS_IN_GAME ~%file%.2da~ AND NOT (~%file%~ STR_EQ ~startare~) THEN BEGIN

        PRINT ~patching campaign file %file%.2da~

		COPY_EXISTING ~%file%.2da~ ~override~ 
			REPLACE_TEXTUALLY ~\(START_\(MP_\)?XP_CAP[ %tab%]+\)\([0-9]+\)[ %tab%]*~ ~\1-1~
			//写法2
			//REPLACE_TEXTUALLY ~\(START_\(MP_\)?XP_CAP[ %tab%]+\)[^0-9-]*\([0-9]+\)[ %tab%]*~ ~\1-1~
        BUT_ONLY
    END
END


//CLABRN03.2DA    hpclass.2da
//EET安装去经验上限一共改动84个2da，再安装铁砧又会对84个2da中的22个重新改动、外加新增4个2da(clabma03.2da/CLABMO02.2DA/CLABMO03.2DA/CLABSH01.2DA)，也就是有62个2da铁砧不会改动、需要借助去经验上限修改。
//实际安装借用CDTWEAKS时，不需要借用去经验上限的xplevel.2da，需要补充没有的SKILLSHM.2DA，实际改动也是84个2da，后面安装IA遇到相同2da会自动覆盖。
//IATweaksByLZ/resources/2da里除clabma03.2da、CLABMO02.2DA、CLABMO03.2DA、CLABSH01.2DA、XPLEVEL.2DA这5个以外的19个2da，需要在上面扩展代码中排除，防止2次操作同一个文件导致卸载时报错。



//IA
COPY ~lzbgmod/IATweaksByLZ/IAKITS/VAGRAN.2DA~    ~ImprovedAnvil/resources/2da~
COPY ~lzbgmod/IATweaksByLZ/IAKITS/AMDK.2DA~      ~ImprovedAnvil/resources/2da~
COPY ~lzbgmod/IATweaksByLZ/IAKITS/RBK.2DA~       ~ImprovedAnvil/resources/2da~
COPY ~lzbgmod/IATweaksByLZ/IAKITS/PROTEC.2DA~    ~ImprovedAnvil/resources/2da~
COPY ~lzbgmod/IATweaksByLZ/IAKITS/ARVOREEN.2DA~  ~ImprovedAnvil/resources/2da~

COPY ~lzbgmod/IATweaksByLZ/resources/2da~   ~ImprovedAnvil/resources/2da~       //根据铁砧规则把等级扩展到50级，每级经验、法术位、豁免、命中等