//CDTWEAKS 5(改)
COPY_EXISTING ~XPCAP.2DA~ ~override~
    REPLACE_TEXTUALLY ~\([A-Za-z_]+[ %tab%]+\)\([0-9]+\)[ %tab%]*~ ~\1-1~
BUT_ONLY
