/// update and patch various IDS lists ///

// update the stats.ids file // Tweak By LZ

OUTER_SET num = 2
OUTER_WHILE (num <= 19) BEGIN
    //OUTER_SET slot_empty = IDS_OF_SYMBOL(~stats~ ~EXTRAPROFICIENCY{%num%}~)   //EXTRAPROFICIENCY%num%分不清EXTRAPROFICIENCY2、EXTRAPROFICIENCY20，要改成EXTRAPROFICIENCY{%num%}
    OUTER_SET slot_empty = IDS_OF_SYMBOL(~stats~ ~EXTRAPROFICIENCY%num%$~)    //同上，$匹配行尾，可以区分EXTRAPROFICIENCY2、EXTRAPROFICIENCY20
    ACTION_IF (slot_empty < 0) BEGIN
        OUTER_PATCH ~~ BEGIN
            FOR (idx = 100; idx < 512; ++idx) BEGIN
                LOOKUP_IDS_SYMBOL_OF_INT value ~stats~ idx
                PATCH_IF (~%value%~ STR_EQ ~%idx%~) BEGIN
                    SET slot_empty = idx
                    SET idx = 512
                END
            END
        END
    END
    ACTION_IF (slot_empty >= 0) BEGIN
	    //APPEND ~stats.ids~ ~%slot_empty% EXTRAPROFICIENCY%num%~ UNLESS ~EXTRAPROFICIENCY{%num%}~    //EXTRAPROFICIENCY%num%分不清EXTRAPROFICIENCY2、EXTRAPROFICIENCY20，要改成EXTRAPROFICIENCY{%num%}
        APPEND ~stats.ids~ ~%slot_empty% EXTRAPROFICIENCY%num%~ UNLESS ~^[0-9]+[ %TAB%]+EXTRAPROFICIENCY%num%$~     //同上，$匹配行尾，可以区分EXTRAPROFICIENCY2、EXTRAPROFICIENCY20。原写法~EXTRAPROFICIENCY%num%$~
    END
	OUTER_SET num = num + 1
END

OUTER_SET num = 7
OUTER_WHILE (num <= 20) BEGIN
    OUTER_SET slot_empty = IDS_OF_SYMBOL(~stats~ ~SCRIPTINGSTATE%num%$~)    //$匹配行尾
    ACTION_IF (slot_empty < 0) BEGIN
        OUTER_PATCH ~~ BEGIN
            FOR (idx = 100; idx < 512; ++idx) BEGIN
                LOOKUP_IDS_SYMBOL_OF_INT value ~stats~ idx
                PATCH_IF (~%value%~ STR_EQ ~%idx%~) BEGIN
                    SET slot_empty = idx
                    SET idx = 512
                END
            END
        END
    END
    ACTION_IF (slot_empty >= 0) BEGIN
        APPEND ~stats.ids~ ~%slot_empty% SCRIPTINGSTATE%num%~ UNLESS ~^[0-9]+[ %TAB%]+SCRIPTINGSTATE%num%$~     //$匹配行尾。原写法~SCRIPTINGSTATE%num%$~
    END
	OUTER_SET num = num + 1
END

/*
原版STATS.IDS编号156~161有12个状态、每2个共用1个编号，铁砧原来是2合1删掉其中1个，重新调整把每2个拆分成不同编号。只对后面BAF编译有效。
游戏已有的BCS如果含157 SCRIPTINGSTATE2或157 DEATH_WARD会自动变为157 SCRIPTINGSTATE2，
后面编译的BAF能识别拆分出的DEATH_WARD，如果采用2合1删掉其中1个则会自动编译为157 SCRIPTINGSTATE2，如果不拆分保持原样则会编译为157 DEATH_WARD。
*/

// 读取 WING_BUFFET 的老槽位（通常返回 156）
OUTER_SET old_slot = IDS_OF_SYMBOL(~stats~ ~WING_BUFFET~)

// 如果 old_slot 等于 156，说明确实需要拆分清理
ACTION_IF (old_slot == 156) BEGIN

    OUTER_SET slot_empty = IDS_OF_SYMBOL(~stats~ ~LZTEMPREPALCE~)
    ACTION_IF (slot_empty < 0) BEGIN
        OUTER_PATCH ~~ BEGIN
            FOR (idx = 100; idx < 512; ++idx) BEGIN
                LOOKUP_IDS_SYMBOL_OF_INT value ~stats~ idx
                PATCH_IF (~%value%~ STR_EQ ~%idx%~) BEGIN
                    SET slot_empty = idx
                    SET idx = 512
                END
            END
        END
	END
    ACTION_IF (slot_empty >= 0) BEGIN
        APPEND ~stats.ids~ ~%slot_empty% LZTEMPREPALCE~ UNLESS ~^[0-9]+[ %TAB%]+LZTEMPREPALCE$~
		COPY_EXISTING ~stats.ids~ ~override~
		    REPLACE_TEXTUALLY ~156 SCRIPTINGSTATE1[%LNL%%MNL%%WNL%]+156 WING_BUFFET~ ~156 SCRIPTINGSTATE1~
		    REPLACE_TEXTUALLY ~%slot_empty%[ %TAB%]+LZTEMPREPALCE~ ~%slot_empty% WING_BUFFET~
		BUT_ONLY
    END
END

// 读取 DEATH_WARD 的老槽位（通常返回 157）
OUTER_SET old_slot = IDS_OF_SYMBOL(~stats~ ~DEATH_WARD~)

// 如果 old_slot 等于 157，说明确实需要拆分清理
ACTION_IF (old_slot == 157) BEGIN

    OUTER_SET slot_empty = IDS_OF_SYMBOL(~stats~ ~LZTEMPREPALCE~)
    ACTION_IF (slot_empty < 0) BEGIN
        OUTER_PATCH ~~ BEGIN
            FOR (idx = 100; idx < 512; ++idx) BEGIN
                LOOKUP_IDS_SYMBOL_OF_INT value ~stats~ idx
                PATCH_IF (~%value%~ STR_EQ ~%idx%~) BEGIN
                    SET slot_empty = idx
                    SET idx = 512
                END
            END
        END
	END
    ACTION_IF (slot_empty >= 0) BEGIN
        APPEND ~stats.ids~ ~%slot_empty% LZTEMPREPALCE~ UNLESS ~^[0-9]+[ %TAB%]+LZTEMPREPALCE$~
		COPY_EXISTING ~stats.ids~ ~override~
		    REPLACE_TEXTUALLY ~157 SCRIPTINGSTATE2[%LNL%%MNL%%WNL%]+157 DEATH_WARD~ ~157 SCRIPTINGSTATE2~
		    REPLACE_TEXTUALLY ~%slot_empty%[ %TAB%]+LZTEMPREPALCE~ ~%slot_empty% DEATH_WARD~
		BUT_ONLY
    END
END

