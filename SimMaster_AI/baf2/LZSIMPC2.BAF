IF
	OR(2)
		Global("LZIMAGAI","GLOBAL",1)
		Global("LZIMAGAI","GLOBAL",3)
	!CheckStat(NearestEnemyOfType([0.0.0.MAGE_ALL]),3,PUPPETMASTERTYPE)
	ObjectActionListEmpty(NearestEnemyOfType([0.0.0.MAGE_ALL]))
	TriggerOverride(NearestEnemyOfType([0.0.0.MAGE_ALL]),Global("ENEMY_SIMULA","LOCALS",0))
THEN
	RESPONSE #100
		ActionOverride(NearestEnemyOfType([0.0.0.MAGE_ALL]),SetGlobal("ENEMY_SIMULA","LOCALS",1))
		ActionOverride(NearestEnemyOfType([0.0.0.MAGE_ALL]),ForceSpellRES("LZWI804",Myself))  // 拟象术
		Continue()
END

