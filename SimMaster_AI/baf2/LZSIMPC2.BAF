	TriggerOverride(TenthNearestEnemyOfType([0.0.0.THIEF_ALL]),Global("ENEMY_SIMULA","LOCALS",0))
THEN
	RESPONSE #100
		ActionOverride(TenthNearestEnemyOfType([0.0.0.THIEF_ALL]),SetGlobal("ENEMY_SIMULA","LOCALS",1))
		ActionOverride(TenthNearestEnemyOfType([0.0.0.THIEF_ALL]),DisplayString(Myself,46153))  // 使用卷轴
		ActionOverride(TenthNearestEnemyOfType([0.0.0.THIEF_ALL]),ForceSpellRES("LZWI804",Myself))  // 拟象术
		Continue()
END

IF
	OR(2)
		Global("LZIMAGAI","GLOBAL",1)
		Global("LZIMAGAI","GLOBAL",3)
	!CheckStat(TenthNearestEnemyOfType([0.0.0.BARD]),3,PUPPETMASTERTYPE)
	ObjectActionListEmpty(TenthNearestEnemyOfType([0.0.0.BARD]))
	TriggerOverride(TenthNearestEnemyOfType([0.0.0.BARD]),Global("ENEMY_SIMULA","LOCALS",0))
THEN
	RESPONSE #100
		ActionOverride(TenthNearestEnemyOfType([0.0.0.BARD]),SetGlobal("ENEMY_SIMULA","LOCALS",1))
		ActionOverride(TenthNearestEnemyOfType([0.0.0.BARD]),DisplayString(Myself,46153))  // 使用卷轴
		ActionOverride(TenthNearestEnemyOfType([0.0.0.BARD]),ForceSpellRES("LZWI804",Myself))  // 拟象术
		Continue()
END

