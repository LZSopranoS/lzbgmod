IF
	Die()
THEN
	RESPONSE #100
		ChangeAIScript("",SPECIFICS)
END

IF
	Global("LZ_it_start","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("LZ_it_start","LOCALS",1)
		SetGlobalTimer("LZ_imagetype_time","LOCALS",TWO_TURNS)
		Continue()
END

IF
	GlobalTimerExpired("LZ_imagetype_time","LOCALS")
THEN
	RESPONSE #100
		ChangeAIScript("",SPECIFICS)
END

IF
	Global("LZ_it_diff","LOCALS",0)
	OR(6)
		XPGT(Player1,3000000)
		XPGT(Player2,3000000)
		XPGT(Player3,3000000)
		XPGT(Player4,3000000)
		XPGT(Player5,3000000)
		XPGT(Player6,3000000)
	XPLT(Player1,5000000)
	XPLT(Player2,5000000)
	XPLT(Player3,5000000)
	XPLT(Player4,5000000)
	XPLT(Player5,5000000)
	XPLT(Player6,5000000)
THEN
	RESPONSE #100
		SetGlobal("LZ_it_diff","LOCALS",1)
		Continue()
END

