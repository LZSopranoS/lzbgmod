		ReallyForceSpell(Myself,ROGUE_SET_SPIKE_TRAP)  // SPCL910.SPL (装设尖刺陷阱)
		ForceSpellRES("SPCL910B",LastSeenBy(Myself))  // No such index
	RESPONSE #50
		IncrementGlobal("LZ_it_settrapc","LOCALS",1)
		SetGlobalTimer("LZ_it_Cast","LOCALS",ONE_ROUND)
