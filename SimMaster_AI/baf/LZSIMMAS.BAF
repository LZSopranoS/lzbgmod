	GlobalLT("LZ_it_wish","LOCALS",2)
	!GlobalTimerNotExpired("LZ_it_Cast","LOCALS")
	!GlobalTimerNotExpired("WishInterval","LOCALS")
	NumCreature("LZSIWISH",0)  // 贵族风巨灵
	!StateCheck(Myself,STATE_DISABLED_CASTING)
	CheckStatLT(Myself,50,SPELLFAILUREMAGE)
	CheckStat(Myself,0,AURACLEANSING)
