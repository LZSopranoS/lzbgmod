IF
	Die()
THEN
	RESPONSE #100
		ApplySpellRES("LZCPAUSE",Player1)  // No such index
		CreateVisualEffectObject("SPUNHOLY",Myself)
END

IF
	Global("LZ_it_Prep","LOCALS",0)
	Allegiance(Myself,NEUTRAL)
	NumberOfTimesTalkedTo(0)
	See([PC])
THEN
	RESPONSE #100
		SetGlobal("LZ_it_Prep","LOCALS",1)
		StartDialogueNoSet(LastSeenBy(Myself))
END

IF
	Global("LZ_it_Prep","LOCALS",1)
	OR(5)
		See(Player6)
		See(Player5)
		See(Player4)
		See(Player3)
		See(Player2)
THEN
	RESPONSE #100
		SetGlobal("LZ_it_Prep","LOCALS",2)
		ReallyForceSpellRES("ohbbclt1",Myself)  // No such index
		ReallyForceSpellRES("LZIPAUSE",Player1)  // No such index
		ForceSpellRES("LZPAUSE",LastSeenBy(Myself))  // No such index
		Continue()
END

IF
	OR(5)
		See([NEUTRAL])
		See([ALLY])
		See([FAMILIAR])
		See([CONTROLLED])
		See([CHARMED])
	InWeaponRange(LastSeenBy(Myself))
	TookDamage()
	!InWeaponRange(LastHitter(Myself))
	WeaponEffectiveVs(LastHitter(Myself),MAINHAND)
	WeaponCanDamage(LastHitter(Myself),MAINHAND)
THEN
	RESPONSE #100
		ReallyForceSpell(LastHitter(Myself),WIZARD_DIMENSION_DOOR)  // SPWI402.SPL (任意门)
		AttackOneRound(LastHitter(Myself))
END

IF
	!See(Player1)
	InMyArea(Player1)
	!StateCheck(Player1,STATE_REALLY_DEAD)
	!StateCheck(Player1,STATE_NOT_APPROACHABLE)
	CheckStat(Player1,0,SANCTUARY)
	Allegiance(Myself,ENEMY)
	!StateCheck(Myself,STATE_DISABLED)
	ActionListEmpty()
THEN
	RESPONSE #100
		MoveToObject(Player1)
END

IF
	SpellCastPriest(Player1,CLERIC_HARM)  // SPPR608.SPL (伤害术)
