		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_sklv5a","LOCALS",0))
		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_sklv5b","LOCALS",0))
		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_sklv4a","LOCALS",0))
		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_sklv4b","LOCALS",0))
		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_sklv4c","LOCALS",0))
