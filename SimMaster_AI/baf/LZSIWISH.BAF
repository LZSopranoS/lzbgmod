		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_sklv3d","LOCALS",0))
		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_sklv2a","LOCALS",0))
		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_sklv1a","LOCALS",0))
		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_sklv6d","LOCALS",0))
		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_miluck","LOCALS",0))
		ActionOverride("LZSIMMAS",SetGlobal("LZ_it_eb","LOCALS",0))
