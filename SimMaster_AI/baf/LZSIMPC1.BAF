	!HasBounceEffects(LastSeenBy(Myself))
	!StateCheck(Myself,STATE_DISABLED_CASTING)
	CheckStatLT(Myself,50,SPELLFAILUREMAGE)
THEN
	RESPONSE #100
		SpellRES("SPWI118",LastSeenBy(Myself))  // 五彩球
END

