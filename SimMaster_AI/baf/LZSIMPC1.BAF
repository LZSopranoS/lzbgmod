IF
	Die()
THEN
	RESPONSE #100
		ChangeAIScript("",SPECIFICS)
END

IF
	Global("LZ_it_start","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("LZ_it_start","LOCALS",1)
		SetGlobalTimer("LZ_imagetype_time","LOCALS",TWO_TURNS)
		Continue()
END

IF
	GlobalTimerExpired("LZ_imagetype_time","LOCALS")
THEN
	RESPONSE #100
		ChangeAIScript("",SPECIFICS)
END

IF
	ActionListEmpty()
	HaveSpellRES("SPWI921")  // 高等迅捷
	See(NearestEnemyOf(Myself))
	CheckStat(Myself,0,AURACLEANSING)
	!StateCheck(Myself,STATE_DISABLED_CASTING)
	CheckStatLT(Myself,50,SPELLFAILUREMAGE)
THEN
	RESPONSE #100
		SpellRES("SPWI921",Myself)  // 高等迅捷
END

IF
	ActionListEmpty()
	HaveSpellRES("SPWI907")  // 绝对免疫
	See(NearestEnemyOf(Myself))
	!StateCheck(Myself,STATE_DISABLED_CASTING)
	CheckStatLT(Myself,50,SPELLFAILUREMAGE)
	AttackedBy([ANYONE],DEFAULT)
	TookDamage()
THEN
	RESPONSE #100
		SpellRES("SPWI907",Myself)  // 绝对免疫
END

