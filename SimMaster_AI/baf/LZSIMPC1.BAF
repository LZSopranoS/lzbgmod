IF
	ActionListEmpty()
	HaveSpellRES("SPWI902")  // 法术陷阱
	!GlobalTimerNotExpired("BUFF_SPWI902","LOCALS")
	OR(4)
		Exists(NearestEnemyOfType([0.0.0.MAGE_ALL]))
		Exists(NearestEnemyOfType([0.0.0.SORCERER]))
		Exists(NearestEnemyOfType([0.0.0.DRUID_ALL]))
		Exists(NearestEnemyOfType([0.0.0.CLERIC_ALL]))
	!StateCheck(Myself,STATE_DISABLED_CASTING)
	CheckStatLT(Myself,50,SPELLFAILUREMAGE)
THEN
	RESPONSE #100
		SetGlobalTimer("BUFF_SPWI902","LOCALS",TWO_TURNS)
		SpellRES("SPWI902",Myself)  // 法术陷阱
END

IF
	ActionListEmpty()
