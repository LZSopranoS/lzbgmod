IF
	Die()
THEN
	RESPONSE #100
		ChangeAIScript("",SPECIFICS)
END

IF
	!See(Player1)
	InMyArea(Player1)
	!StateCheck(Player1,STATE_REALLY_DEAD)
	!StateCheck(Player1,STATE_NOT_APPROACHABLE)
	CheckStat(Player1,0,SANCTUARY)
	Allegiance(Myself,ENEMY)
	!StateCheck(Myself,STATE_DISABLED)
	ActionListEmpty()
THEN
	RESPONSE #100
		MoveToObject(Player1)
END

IF
	Global("LZ_it_ia","LOCALS",0)
	!GlobalTimerNotExpired("LZ_it_Cast","LOCALS")
	!StateCheck(Myself,STATE_DISABLED_CASTING)
	CheckStatLT(Myself,50,SPELLFAILUREMAGE)
	CheckStat(Myself,0,AURACLEANSING)
	Allegiance(Myself,ENEMY)
	See(NearestEnemyOf(Myself))
THEN
	RESPONSE #100
		SetGlobal("LZ_it_ia","LOCALS",1)
		SetGlobalTimer("LZ_it_Cast","LOCALS",ONE_ROUND)
		ForceSpellRES("SPWI921",Myself)  // 高等迅捷
END

IF
	GlobalLT("LZ_it_pfmw","LOCALS",2)
	OR(2)
		!GlobalTimerNotExpired("LZ_it_Cast","LOCALS")
		CheckStatGT(Myself,0,AURACLEANSING)
	!StateCheck(Myself,STATE_DISABLED_CASTING)
	CheckStatLT(Myself,50,SPELLFAILUREMAGE)
	Allegiance(Myself,ENEMY)
	AttackedBy([ANYONE],DEFAULT)
	TookDamage()
THEN
	RESPONSE #100
		IncrementGlobal("LZ_it_pfmw","LOCALS",1)
		SetGlobalTimer("LZ_it_Cast","LOCALS",ONE_ROUND)
		ForceSpellRES("SPWI611",Myself)  // 防护魔法武器
END

