	CheckStatLT(LastSeenBy(Myself),40,RESISTFIRE)
	CheckStatLT(LastSeenBy(Myself),40,RESISTELECTRICITY)
	!HasBounceEffects(LastSeenBy(Myself))
THEN
	RESPONSE #50
		SetGlobal("LZ_it_sklv3d","LOCALS",1)
		SetGlobalTimer("LZ_it_Cast","LOCALS",ONE_ROUND)
