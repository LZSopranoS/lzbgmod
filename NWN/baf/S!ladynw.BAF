IF
	!GlobalTimerNotExpired("Iaspell","LOCALS")
	Allegiance(Myself,ENEMY)
	See([PC])
	CheckStatGT(LastSeenBy(Myself),0,RESISTELECTRICITY)
	Global("LowerElectric","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("LowerElectric","LOCALS",1)
