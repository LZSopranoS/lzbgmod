IF
	See(NearestEnemyOf(Myself))
	Global("Ianobmar01","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("Ianobmar01","LOCALS",1)
		SetGlobalTimer("Iaspell","LOCALS",ONE_ROUND)
		SetGlobalTimer("pfmw","LOCALS",FOUR_ROUNDS)
		ReallyForceSpell(Myself,DRAGON_STONE_SKIN)  // SPIN694.SPL (石肤术)
		ReallyForceSpell(Myself,WIZARD_FIRE_SHIELD_RED)  // SPWI418.SPL (火焰护盾（红）)
		ReallyForceSpell(Myself,WIZARD_FIRE_SHIELD_BLUE)  // SPWI403.SPL (火焰盾（蓝）)
		ReallyForceSpell(Myself,PROTECTION_MAGIC_WEAPON_NOEFF)  // SPIN686.SPL (防护魔法武器)
		ReallyForceSpellRES("SPWII02",Myself)
		ReallyForceSpellRES("SPWII03",Myself)
		ReallyForceSpellRES("jwglobe",Myself)  // 法术无效结界
END

IF
	Allegiance(Myself,ENEMY)
	Detect([PC])
	Global("Iacreature","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("Iacreature","LOCALS",1)
		CreateCreatureObject("S!lady5",Myself,0,0,0)
		CreateCreatureObject("S!lady5",Myself,0,0,0)
END

IF
	Allegiance(Myself,ENEMY)
	OR(2)
		Detect([PC])
		Detect([GOODCUTOFF])
	Global("partyfled","LOCALS",1)
THEN
	RESPONSE #100
		SetGlobal("partyfled","LOCALS",0)
END

IF
	Allegiance(Myself,ENEMY)
	!GlobalTimerNotExpired("Iaspell","LOCALS")
	See([PC])
	CheckStatLT(Myself,1,STONESKINS)
	OR(3)
		Range(LastSeenBy(Myself),5)
		AttackedBy(LastSeenBy(Myself),MELEE)
		AttackedBy(LastSeenBy(Myself),RANGED)
	OR(3)
		!GlobalTimerNotExpired("pfmw","LOCALS")
		!CheckSpellState(Myself,PROTECTION_FROM_MAGICAL_WEAPONS)
		!CheckStatGT(Myself,0,SCRIPTINGSTATE6)
	GlobalLT("Ianobmar04","LOCALS",3)
THEN
	RESPONSE #100
		IncrementGlobal("Ianobmar04","LOCALS",1)
		SetGlobalTimer("Iaspell","LOCALS",ONE_ROUND)
		SetGlobalTimer("pfmw","LOCALS",FOUR_ROUNDS)
		ReallyForceSpell(Myself,PROTECTION_MAGIC_WEAPON_NOEFF)  // SPIN686.SPL (防护魔法武器)
END

IF
	Allegiance(Myself,ENEMY)
	!GlobalTimerNotExpired("Iaspell","LOCALS")
	See([PC])
	OR(3)
		StateCheck(LastSeenBy(Myself),STATE_IMPROVEDINVISIBILITY)
		StateCheck(LastSeenBy(Myself),STATE_INVISIBLE)
		StateCheck(LastSeenBy(Myself),STATE_MIRRORIMAGE)
	!GlobalTimerNotExpired("truesight","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("truesight","LOCALS",TEN_ROUNDS)
		SetGlobalTimer("Iaspell","LOCALS",ONE_ROUND)
		ReallyForceSpell(Myself,WIZARD_TRUE_SIGHT)  // SPWI609.SPL (真实视域)
END

IF
	Allegiance(Myself,ENEMY)
	!GlobalTimerNotExpired("Iaspell","LOCALS")
	See(SecondNearest([PC]))
	OR(3)
		StateCheck(LastSeenBy(Myself),STATE_IMPROVEDINVISIBILITY)
		StateCheck(LastSeenBy(Myself),STATE_INVISIBLE)
		StateCheck(LastSeenBy(Myself),STATE_MIRRORIMAGE)
