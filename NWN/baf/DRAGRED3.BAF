IF
	Allegiance(Myself,ENEMY)
	Global("Iafirkra01","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("Iafirkra01","LOCALS",1)
		ReallyForceSpell(Myself,DRAGON_STONE_SKIN)  // SPIN694.SPL (石肤术)
		ReallyForceSpellRES("SPWII03",Myself)
		ReallyForceSpellRES("jwglobe",Myself)  // 法术无效结界
		ReallyForceSpellRES("SPWII02",Myself)
		ReallyForceSpellRES("SPWII01",Myself)
END

IF
	See(NearestEnemyOf(Myself))
	Global("partyfled","LOCALS",1)
THEN
	RESPONSE #100
		SetGlobal("partyfled","LOCALS",0)
END

IF
	Allegiance(Myself,ENEMY)
	See([PC])
	Range(LastSeenBy(Myself),11)
	Global("Iacreature","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("Iacreature","LOCALS",1)
		SetInterrupt(FALSE)
		ForceSpell(LastSeenBy(Myself),DRAGON_WING_BUFFET)  // SPIN695.SPL (龙翼拍击)
		Wait(1)
		CreateCreatureObject("S!salasu",Myself,0,0,0)
		CreateCreatureObject("S!salasu",Myself,0,0,0)
		SetInterrupt(TRUE)
END

