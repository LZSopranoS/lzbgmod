IF
	Allegiance(Myself,ENEMY)
	InMyArea(Player1)
	Global("Iapccloud","LOCALS",0)
	OR(24)
		SpellCast(SixthNearest([PC]),WIZARD_INCENDIARY_CLOUD)  // SPWI810.SPL (焚云术)
		SpellCast(SixthNearest([PC]),WIZARD_STINKING_CLOUD)  // SPWI213.SPL (臭云术)
		SpellCast(SixthNearest([PC]),WIZARD_CLOUDKILL)  // SPWI502.SPL (死云术)
		SpellCast(SixthNearest([PC]),WIZARD_DEATH_FOG)  // SPWI614.SPL (死亡之雾)
		SpellCast(FifthNearest([PC]),WIZARD_INCENDIARY_CLOUD)  // SPWI810.SPL (焚云术)
		SpellCast(FifthNearest([PC]),WIZARD_STINKING_CLOUD)  // SPWI213.SPL (臭云术)
		SpellCast(FifthNearest([PC]),WIZARD_CLOUDKILL)  // SPWI502.SPL (死云术)
		SpellCast(FifthNearest([PC]),WIZARD_DEATH_FOG)  // SPWI614.SPL (死亡之雾)
		SpellCast(FourthNearest([PC]),WIZARD_INCENDIARY_CLOUD)  // SPWI810.SPL (焚云术)
		SpellCast(FourthNearest([PC]),WIZARD_STINKING_CLOUD)  // SPWI213.SPL (臭云术)
		SpellCast(FourthNearest([PC]),WIZARD_CLOUDKILL)  // SPWI502.SPL (死云术)
		SpellCast(FourthNearest([PC]),WIZARD_DEATH_FOG)  // SPWI614.SPL (死亡之雾)
		SpellCast(ThirdNearest([PC]),WIZARD_INCENDIARY_CLOUD)  // SPWI810.SPL (焚云术)
		SpellCast(ThirdNearest([PC]),WIZARD_STINKING_CLOUD)  // SPWI213.SPL (臭云术)
		SpellCast(ThirdNearest([PC]),WIZARD_CLOUDKILL)  // SPWI502.SPL (死云术)
		SpellCast(ThirdNearest([PC]),WIZARD_DEATH_FOG)  // SPWI614.SPL (死亡之雾)
		SpellCast(SecondNearest([PC]),WIZARD_INCENDIARY_CLOUD)  // SPWI810.SPL (焚云术)
		SpellCast(SecondNearest([PC]),WIZARD_STINKING_CLOUD)  // SPWI213.SPL (臭云术)
		SpellCast(SecondNearest([PC]),WIZARD_CLOUDKILL)  // SPWI502.SPL (死云术)
		SpellCast(SecondNearest([PC]),WIZARD_DEATH_FOG)  // SPWI614.SPL (死亡之雾)
		SpellCast([PC],WIZARD_INCENDIARY_CLOUD)  // SPWI810.SPL (焚云术)
		SpellCast([PC],WIZARD_STINKING_CLOUD)  // SPWI213.SPL (臭云术)
		SpellCast([PC],WIZARD_CLOUDKILL)  // SPWI502.SPL (死云术)
		SpellCast([PC],WIZARD_DEATH_FOG)  // SPWI614.SPL (死亡之雾)
	Delay(2)
THEN
	RESPONSE #100
		SetGlobal("Iapccloud","LOCALS",1)
		ForceSpell(Myself,CLERIC_ZONE_OF_SWEET_AIR)  // SPPR318.SPL (空气滤净)
		MoveToObject(Player1)
END

IF
	Allegiance(Myself,ENEMY)
	!GlobalTimerNotExpired("Iasilence2","LOCALS")
	See(NearestEnemyOfType([PC.0.0.MAGE_ALL]))
	CheckStatGT(LastSeenBy(Myself),0,AURACLEANSING)
	!StateCheck(LastSeenBy(Myself),STATE_SILENCED)
	GlobalLT("Iagsilence","LOCALS",4)
THEN
	RESPONSE #100
		IncrementGlobal("Iagsilence","LOCALS",1)
		SetGlobalTimer("Iasilence2","LOCALS",ONE_ROUND)
		SetGlobalTimer("Iasilence","LOCALS",THREE_ROUNDS)
		SetInterrupt(FALSE)
		ForceSpell(LastSeenBy(Myself),DRAGON_SILENCE)  // SPIN692.SPL (十五呎沉默术)
		Wait(1)
		ActionOverride(LastSeenBy(Myself),EquipMostDamagingMelee())
		SetInterrupt(TRUE)
END

