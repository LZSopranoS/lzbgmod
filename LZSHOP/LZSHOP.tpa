LOAD_TRA ~lzbgmod/LZSHOP/lang/schinese/install.tra~

COPY ~lzbgmod/LZSHOP/copy~ ~override~

ACTION_IF NOT FILE_EXISTS_IN_GAME ~M_LZPATH.lua~ THEN BEGIN
