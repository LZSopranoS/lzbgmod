COMPILE ~lzbgmod/LZSHOP/d~

COMPILE ~lzbgmod/LZSHOP/baf~

	//FIND_TRAPS BUTTON
    OUTER_SET slot_setbutton = IDS_OF_SYMBOL(~splstate~ ~LZFTBUTTON~)
    ACTION_IF (slot_setbutton < 0) BEGIN
      OUTER_PATCH ~~ BEGIN
        FOR (idx = 100; idx < 256; ++idx) BEGIN
          LOOKUP_IDS_SYMBOL_OF_INT value ~splstate~ idx
          PATCH_IF (~%value%~ STR_EQ ~%idx%~) BEGIN
            SET slot_setbutton = idx
            SET idx = 256
          END
        END
      END
/*	
    // --- 第二步：将找到的 idx 赋值给一个全局变量以便后续使用 ---
    // 注意：在 OUTER_PATCH 中计算的变量是局部的，必须用 OUTER_SET 传出来
    OUTER_SET found_idx = slot_setbutton
    // --- 第三步：修改 Lua 文件 --- 使用 %found_idx% 将变量值插入到文本替换中
    COPY_EXISTING ~M_LZBT.lua~ ~override~
    REPLACE_TEXTUALLY ~EEex_Sprite_GetSpellState(sprite, 64)~
    ~EEex_Sprite_GetSpellState(sprite, %found_idx%)~
    BUT_ONLY
*/
      ACTION_IF (slot_setbutton >= 0) BEGIN
	    //COPY ~lzbgmod/LZSHOP/lua/M_LZBT.lua~ ~override~
	    COPY_EXISTING ~M_LZBT.lua~ ~override~
		REPLACE_TEXTUALLY ~EEex_Sprite_GetSpellState(sprite, LZFTBUTTON119)~
        ~EEex_Sprite_GetSpellState(sprite, %slot_setbutton%)~
		BUT_ONLY
        APPEND ~splstate.ids~ ~%slot_setbutton% LZFTBUTTON~ UNLESS ~LZFTBUTTON~
        CLEAR_IDS_MAP
      END
    END
	COPY_EXISTING ~FTBUTTON.ITM~ ~override~
        LPF ADD_ITEM_EFFECT
        INT_VAR
          insert_point = 0  // add on top
          opcode = 328      // Set spell state
          target = 1        // Self
          parameter2 = slot_setbutton
          timing = 9
          //duration = 0
          special = 1       // use spell states from table
        END

        LPF ADD_ITEM_EFFECT
        INT_VAR
          insert_point = 0  // add on top
          opcode = 321      // Remove effects by resource
          target = 1        // Self
          timing = 1
        STR_VAR
          resource = ~FTBUTTON~
        END
		
	//STEALTH BUTTON
    OUTER_SET slot_setbutton = IDS_OF_SYMBOL(~splstate~ ~LZSBUTTON~)
    ACTION_IF (slot_setbutton < 0) BEGIN
      OUTER_PATCH ~~ BEGIN
        FOR (idx = 100; idx < 256; ++idx) BEGIN
          LOOKUP_IDS_SYMBOL_OF_INT value ~splstate~ idx
          PATCH_IF (~%value%~ STR_EQ ~%idx%~) BEGIN
            SET slot_setbutton = idx
            SET idx = 256
          END
        END
      END
      ACTION_IF (slot_setbutton >= 0) BEGIN
	    COPY_EXISTING ~M_LZBT.lua~ ~override~
		REPLACE_TEXTUALLY ~EEex_Sprite_GetSpellState(sprite, LZSBUTTON127)~
        ~EEex_Sprite_GetSpellState(sprite, %slot_setbutton%)~
		BUT_ONLY
        APPEND ~splstate.ids~ ~%slot_setbutton% LZSBUTTON~ UNLESS ~LZSBUTTON~
        CLEAR_IDS_MAP
      END
    END
	COPY_EXISTING ~SBUTTON.ITM~ ~override~
        LPF ADD_ITEM_EFFECT
        INT_VAR
          insert_point = 0  // add on top
          opcode = 328      // Set spell state
