        LPF ADD_ITEM_EFFECT
        INT_VAR
          insert_point = 0  // add on top
          opcode = 321      // Remove effects by resource
          target = 1        // Self
          timing = 1
        STR_VAR
          resource = ~QWBUTON1~
        END
        LPF ADD_ITEM_EFFECT
        INT_VAR
          insert_point = 0  // add on top
          opcode = 321      // Remove effects by resource
          target = 1        // Self
          timing = 1
        STR_VAR
          resource = ~QWBUTON2~
        END
        LPF ADD_ITEM_EFFECT
        INT_VAR
          insert_point = 0  // add on top
          opcode = 321      // Remove effects by resource
          target = 1        // Self
          timing = 1
        STR_VAR
          resource = ~QWBUTON3~
        END		
//END ELSE BEGIN                               //快捷键改为F，兼容了CDTWEAKS全部职业/宗派拥有四个武器栏组件的类似功能，删除物品就不需要了
    //COPY_EXISTING ~LZSHOP.STO~    ~override~
      //REMOVE_STORE_ITEM ~QWBUTON2~ ~QWBUTON3~
    //BUT_ONLY
//END

COPY_EXISTING ~thiefscl.2da~ ~override~
  COUNT_2DA_COLS num_cols
  COUNT_2DA_ROWS num_cols num_rows
  SET col_limit = num_cols - 1  //直接用num_cols会导致后面读class_value读不出职业、读的是下一行。		
  FOR (col = 1; col < col_limit; ++col) BEGIN
    READ_2DA_ENTRY 0 col col_limit class_value
    //PATCH_IF (NOT "%class_value%" STR_EQ "OHTYR" AND NOT "%class_value%" STR_EQ "OHTEMPUS") BEGIN  //会导致SHAMAN列下面数据没改。
	PATCH_IF (NOT "%class_value%" STR_EQ "OHTEMPUS") BEGIN  //上面row为0且col_limit和下面row为0且num_cols在2da里是上下两行，用PRINT调试读上一行class_value下的值实际是前一列的值，所以用NOT "OHTEMPUS"判断。
      FOR (row = 0; row < num_rows; ++row) BEGIN            //row为0读的是PICK_POCKETS那一行。
        READ_2DA_ENTRY row 0 num_cols skill_name
        //PATCH_IF ("%skill_name%" STR_EQ ("PICK_POCKETS" OR "OPEN_LOCKS" OR "FIND_TRAPS" OR "MOVE_SILENTLY" OR "HIDE_IN_SHADOWS" OR "DETECT_ILLUSION")) BEGIN
		PATCH_IF ("%skill_name%" STR_EQ "PICK_POCKETS" OR "%skill_name%" STR_EQ "OPEN_LOCKS" OR "%skill_name%" STR_EQ "FIND_TRAPS" OR "%skill_name%" STR_EQ "MOVE_SILENTLY" OR "%skill_name%" STR_EQ "HIDE_IN_SHADOWS" OR "%skill_name%" STR_EQ "DETECT_ILLUSION") BEGIN
          READ_2DA_ENTRY row col num_cols cell_value
          PATCH_IF (cell_value == 0) BEGIN
            SET_2DA_ENTRY row col num_cols 100
          END
        END
      END
    END
  END
  PRETTY_PRINT_2DA  //必加，否则改完很乱不会自动对齐。
BUT_ONLY_IF_IT_CHANGES

