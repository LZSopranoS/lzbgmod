IF
	Global("LZSKPONT","GLOBAL",2)
THEN
	RESPONSE #100
		SetGlobal("LZSKPONT","GLOBAL",1)
		ChangeStat(LastSummonerOf(Myself),TRAPS,5,ADD)
		CreateVisualEffectObject("ASUMM1X",LastSummonerOf(Myself))
		Continue()
END

