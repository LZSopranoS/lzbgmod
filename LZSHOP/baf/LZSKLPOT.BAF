IF
	Global("LZSKPONT","GLOBAL",1)
	ActionListEmpty()
THEN
	RESPONSE #100
		SetGlobal("LZSKPONT","GLOBAL",0)
		DestroySelf()
END

IF
	GlobalGT("LZSKPONT","GLOBAL",1)
	ActionListEmpty()
	Delay(2)
THEN
	RESPONSE #100
		SetGlobal("LZSKPONT","GLOBAL",0)
		DestroySelf()
END

