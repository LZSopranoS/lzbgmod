IF
	Global("LZSKPONT","GLOBAL",30)
	NumItemsPartyGT("SCRL72",0)  // 友好术
	EEex_LuaTrigger("return LZXPABOVE1()")
THEN
	RESPONSE #100
		SetGlobal("LZSKPONT","GLOBAL",1)
		TakePartyItemNum("SCRL72",1)  // 友好术
		DestroyItem("SCRL72")  // 友好术
		AddXPObject(LastSummonerOf(Myself),-50000)
		ActionOverride(LastSummonerOf(Myself),AddSpecialAbility("LZSPLA01"))  // 友好术
		CreateVisualEffectObject("ASUMM1X",LastSummonerOf(Myself))
		Continue()
END

