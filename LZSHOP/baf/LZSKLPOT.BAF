IF
	Global("LZSKPONT","GLOBAL",20)
	EEex_LuaTrigger("return LZXPABOVE2()")
THEN
	RESPONSE #100
		SetGlobal("LZSKPONT","GLOBAL",1)
		AddXPObject(LastSummonerOf(Myself),-100000)
		ActionOverride(LastSummonerOf(Myself),AddSpecialAbility("SPDWD02"))  // 防御姿态
		CreateVisualEffectObject("ASUMM1X",LastSummonerOf(Myself))
		Continue()
END

