IF
	Global("LZSHOPItemChange","BG0800",0)
	AreaCheck("BG0800")
	InMyArea([PC])
THEN
	RESPONSE #100
		SetGlobal("LZSHOPItemChange","BG0800",1)
		RemoveStoreItem("LZSHOP","LZENSONG",1)  // 强力吟唱
		RemoveStoreItem("LZSHOP","LZUSEITM",1)  // 万能巧手
		RemoveStoreItem("LZSHOP","LZSPLA08",1)  // 愿望术
		RemoveStoreItem("LZSHOP","LZSPLA09",1)  // 律令：死亡
		RemoveStoreItem("LZSHOP","LZSPLA10",1)  // 形态改变
END

IF
	Global("LZSHOPItemChange","AR0400",0)  // Slums
	AreaCheck("AR0400")  // Slums
	InMyArea([PC])
THEN
	RESPONSE #100
		SetGlobal("LZSHOPItemChange","AR0400",1)  // Slums
		AddStoreItem("LZSHOP","LZSPLA08",1,1)  // 愿望术
		AddStoreItem("LZSHOP","LZSPLA09",1,1)  // 律令：死亡
		AddStoreItem("LZSHOP","LZSPLA10",1,1)  // 形态改变
		AddStoreItem("LZSHOP","LZENSONG",1,1)  // 强力吟唱
		AddStoreItem("LZSHOP","LZUSEITM",1,1)  // 万能巧手
END

IF
	Global("LZSHOPEquipWeapon","LOCALS",0)
	!GlobalTimerNotExpired("LZSHOPCombatTimer","LOCALS")
	!GlobalTimerNotExpired("LZSHOPDSTimer","LOCALS")
	See([PC])
THEN
	RESPONSE #40
		SetGlobalTimer("LZSHOPDSTimer","LOCALS",TWO_TURNS)
		DisplayString(Myself,@104)  // LZ技能商店，盗贼的寻找陷阱、侦测幻象、潜行，诗人的战歌，牧师的超度亡灵...，普通的、特殊的、高阶的应有尽有，集齐战法盗牧诗特长于一身不再是梦想...
		Continue()
	RESPONSE #40
		SetGlobalTimer("LZSHOPDSTimer","LOCALS",ONE_TURN)
		DisplayString(Myself,@104)  // LZ技能商店，盗贼的寻找陷阱、侦测幻象、潜行，诗人的战歌，牧师的超度亡灵...，普通的、特殊的、高阶的应有尽有，集齐战法盗牧诗特长于一身不再是梦想...
		Continue()
	RESPONSE #20
		SetGlobalTimer("LZSHOPDSTimer","LOCALS",FIVE_ROUNDS)
		Continue()
END

IF
	Global("LZSHOPEquipWeapon","LOCALS",0)
	!GlobalTimerNotExpired("LZSHOPCombatTimer","LOCALS")
	OR(11)
		AttackedBy([ANYONE],DEFAULT)
		HitBy([ANYONE],ACID)
		HitBy([ANYONE],COLD)
		HitBy([ANYONE],ELECTRICITY)
		HitBy([ANYONE],FIRE)
		HitBy([ANYONE],POISON)
		HitBy([ANYONE],MAGIC)
		HitBy([ANYONE],CRUSHING)
		HitBy([ANYONE],PIERCING)
		HitBy([ANYONE],MISSILE)
		HitBy([ANYONE],SLASHING)
	!HasItemEquipedReal("SW1H77",Myself)  // 答复者+4
	!HasItemEquiped("STDEATH",Myself)  // 影之刃+3
THEN
	RESPONSE #100
		SetGlobal("LZSHOPEquipWeapon","LOCALS",1)
		SetGlobalTimer("LZSHOPCombatTimer","LOCALS",ONE_TURN)
		SetInterrupt(FALSE)
		CreateItem("SW1H77",0,0,0)  // 答复者+4
		XEquipItem("SW1H77",Myself,SLOT_WEAPON0,EQUIP)  // 答复者+4
		CreateItem("STDEATH",0,0,0)  // 影之刃+3
		XEquipItem("STDEATH",Myself,SLOT_SHIELD,EQUIP)  // 影之刃+3
		SetInterrupt(TRUE)
		Continue()
END

IF
	Global("LZSHOPEquipWeapon","LOCALS",1)
	!GlobalTimerNotExpired("LZSHOPVisualBuff","LOCALS")
	HasItem("LZSHOPSP",Myself)  // 火焰护盾（蓝）
THEN
	RESPONSE #100
		SetGlobalTimer("LZSHOPVisualBuff","LOCALS",ONE_TURN)
		UseItem("LZSHOPSP",Myself)  // 火焰护盾（蓝）
		Continue()
END

IF
	GlobalTimerNotExpired("LZSHOPCombatTimer","LOCALS")
	AttackedBy([ANYONE],DEFAULT)
	RandomNum(2,1)
THEN
	RESPONSE #100
		AttackOneRound(LastAttackerOf(Myself))
	RESPONSE #100
		ForceSpellRange(LastAttackerOf(Myself),ROGUE_SET_SPIKE_TRAP)  // SPCL910.SPL (装设尖刺陷阱)
		ForceSpellRangeRES("SPCL910B",LastAttackerOf(Myself))  // No such index
		ForceSpellRange(LastAttackerOf(Myself),ROGUE_SET_EXPLODING_TRAP)  // SPCL911.SPL (装设爆裂陷阱)
		ForceSpellRangeRES("SPCL911B",LastAttackerOf(Myself))  // No such index
		ForceSpellRange(LastAttackerOf(Myself),ROGUE_SET_SPIKE_TRAP)  // SPCL910.SPL (装设尖刺陷阱)
		ForceSpellRangeRES("SPCL910B",LastAttackerOf(Myself))  // No such index
		ForceSpellRange(LastAttackerOf(Myself),ROGUE_SET_EXPLODING_TRAP)  // SPCL911.SPL (装设爆裂陷阱)
		ForceSpellRangeRES("SPCL911B",LastAttackerOf(Myself))  // No such index
		ForceSpellRange(LastAttackerOf(Myself),ROGUE_SET_SPIKE_TRAP)  // SPCL910.SPL (装设尖刺陷阱)
		ForceSpellRangeRES("SPCL910B",LastAttackerOf(Myself))  // No such index
	RESPONSE #100
		ForceSpellRange(LastAttackerOf(Myself),WIZARD_DRAGONS_BREATH)  // SPWI922.SPL (龙息术)
		ForceSpellRange(LastAttackerOf(Myself),WIZARD_COMET)  // SPWI925.SPL (彗星术)
		ForceSpellRange(LastAttackerOf(Myself),WIZARD_DRAGONS_BREATH)  // SPWI922.SPL (龙息术)
		ForceSpellRange(LastAttackerOf(Myself),WIZARD_COMET)  // SPWI925.SPL (彗星术)
		ForceSpellRange(LastAttackerOf(Myself),WIZARD_DRAGONS_BREATH)  // SPWI922.SPL (龙息术)
	RESPONSE #100
		ForceSpellRange(LastAttackerOf(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
		ForceSpellRange(LastAttackerOf(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
		ForceSpellRange(LastAttackerOf(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
		ForceSpellRange(LastAttackerOf(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
		ForceSpellRange(LastAttackerOf(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
END

IF
	GlobalTimerNotExpired("LZSHOPCombatTimer","LOCALS")
	OR(10)
		HitBy([ANYONE],ACID)
		HitBy([ANYONE],COLD)
		HitBy([ANYONE],ELECTRICITY)
		HitBy([ANYONE],FIRE)
		HitBy([ANYONE],POISON)
		HitBy([ANYONE],MAGIC)
		HitBy([ANYONE],CRUSHING)
		HitBy([ANYONE],PIERCING)
		HitBy([ANYONE],MISSILE)
		HitBy([ANYONE],SLASHING)
	RandomNum(2,2)
THEN
	RESPONSE #100
		AttackOneRound(LastHitter(Myself))
	RESPONSE #100
		ForceSpellRange(LastHitter(Myself),ROGUE_SET_SPIKE_TRAP)  // SPCL910.SPL (装设尖刺陷阱)
		ForceSpellRangeRES("SPCL910B",LastHitter(Myself))  // No such index
