		ForceSpellRangeRES("SPCL911B",LastHitter(Myself))  // No such index
		ForceSpellRange(LastHitter(Myself),ROGUE_SET_SPIKE_TRAP)  // SPCL910.SPL (装设尖刺陷阱)
		ForceSpellRangeRES("SPCL910B",LastHitter(Myself))  // No such index
	RESPONSE #100
		ForceSpellRange(LastHitter(Myself),WIZARD_DRAGONS_BREATH)  // SPWI922.SPL (龙息术)
		ForceSpellRange(LastHitter(Myself),WIZARD_COMET)  // SPWI925.SPL (彗星术)
		ForceSpellRange(LastHitter(Myself),WIZARD_DRAGONS_BREATH)  // SPWI922.SPL (龙息术)
		ForceSpellRange(LastHitter(Myself),WIZARD_COMET)  // SPWI925.SPL (彗星术)
		ForceSpellRange(LastHitter(Myself),WIZARD_DRAGONS_BREATH)  // SPWI922.SPL (龙息术)
	RESPONSE #100
		ForceSpellRange(LastHitter(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
		ForceSpellRange(LastHitter(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
		ForceSpellRange(LastHitter(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
		ForceSpellRange(LastHitter(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
		ForceSpellRange(LastHitter(Myself),CLERIC_IMPLOSION)  // SPPR728.SPL (内爆术)
END

IF
	Global("LZSHOPEquipWeapon","LOCALS",1)
	GlobalTimerExpired("LZSHOPCombatTimer","LOCALS")
	HasItemEquipedReal("SW1H77",Myself)  // 答复者+4
	HasItemEquiped("STDEATH",Myself)  // 影之刃+3
	ActionListEmpty()
THEN
	RESPONSE #100
		SetGlobal("LZSHOPEquipWeapon","LOCALS",0)
		DestroyItem("SW1H77")  // 答复者+4
		DestroyItem("STDEATH")  // 影之刃+3
		Continue()
END

IF
	OR(4)
		StateCheck(Myself,STATE_SLEEPING)
		StateCheck(Myself,STATE_HELPLESS)
		StateCheck(Myself,STATE_BLIND)
		!CheckStat(Myself,0,POLYMORPHED)
THEN
	RESPONSE #100
		ReallyForceSpell(Myself,WIZARD_TRUE_DISPEL_MAGIC)  // SPWI326.SPL (解除魔法)
		Continue()
END

IF
	Allegiance(Myself,ENEMY)
	OR(4)
		SpellCastPriest([ANYONE],CLERIC_MISCAST_MAGIC)  // SPPR310.SPL (封魔术)
		SpellCastPriest([ANYONE],CLERIC_SUMMON_INSECTS)  // SPPR319.SPL (召唤昆虫)
		SpellCastPriest([ANYONE],CLERIC_INSECT_PLAGUE)  // SPPR517.SPL (疫病虫群)
		SpellCastPriest([ANYONE],CLERIC_CREEPING_DOOM)  // SPPR717.SPL (漫天虫蚀)
	!GlobalTimerNotExpired("SOSStateTimer","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("SOSStateTimer","LOCALS",ONE_ROUND)
		Continue()
END

IF
	GlobalTimerNotExpired("SOSStateTimer","LOCALS")
	CheckStatGT(Myself,49,SPELLFAILUREMAGE)
THEN
	RESPONSE #100
		ReallyForceSpell(Myself,WIZARD_TRUE_DISPEL_MAGIC)  // SPWI326.SPL (解除魔法)
		Wait(2)
		Continue()
END

IF
	SpellCastPriest(Player1,CLERIC_HARM)  // SPPR608.SPL (伤害术)
	HasItem("HARM",Player1)  // 伤害术
THEN
	RESPONSE #100
		ReallyForceSpell(Player1,WIZARD_REMOVE_MAGIC)  // SPWI302.SPL (移除魔法)
END

