IF
	OR(6)
		CheckStatLT(Myself,15,STR)
		CheckStatLT(Myself,15,DEX)
		CheckStatLT(Myself,15,CON)
		CheckStatLT(Myself,15,INT)
		CheckStatLT(Myself,15,WIS)
		CheckStatLT(Myself,15,CHR)
	!GlobalTimerNotExpired("LZSHOPCastTimer","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("LZSHOPCastTimer","LOCALS",FIVE_ROUNDS)
		DisplayString(Myself,40252)  // 意外术－防护魔法武器
		ReallyForceSpell(Myself,WIZARD_PROTECTION_FROM_MAGIC_WEAPONS)  // SPWI611.SPL (防护魔法武器)
		DisplayString(Myself,39969)  // 法术定序－已用出
		ReallyForceSpell(Myself,WIZARD_STONE_SKIN)  // SPWI408.SPL (石肤术)
		ReallyForceSpell(Myself,WIZARD_FIRE_SHIELD_RED)  // SPWI418.SPL (火焰护盾（红）)
		ReallyForceSpell(Myself,WIZARD_IMPROVED_INVISIBILITY)  // SPWI405.SPL (高等隐形术)
		DisplayString(Myself,39968)  // 法术启动－已用出
		ReallyForceSpell(Myself,WIZARD_PROTECTION_FROM_MAGIC_ENERGY)  // SPWI606.SPL (防护魔法能量)
		ReallyForceSpell(Myself,WIZARD_GLOBE_OF_INVULNERABILITY)  // SPWI602.SPL (法术无效结界)
		ReallyForceSpell(Myself,WIZARD_SPELL_IMMUNITY_ABJURATION)  // SPWI590.SPL (法术免疫：防护系)
		Continue()
END

IF
	OR(5)
		See([NEUTRAL])
		See([ALLY])
		See([FAMILIAR])
		See([CONTROLLED])
		See([CHARMED])
	InWeaponRange(LastSeenBy(Myself))
	TookDamage()
	!InWeaponRange(LastHitter(Myself))
	WeaponEffectiveVs(LastHitter(Myself),MAINHAND)
	WeaponCanDamage(LastHitter(Myself),MAINHAND)
THEN
	RESPONSE #100
		ReallyForceSpell(LastHitter(Myself),WIZARD_DIMENSION_DOOR)  // SPWI402.SPL (任意门)
		AttackOneRound(LastHitter(Myself))
END

