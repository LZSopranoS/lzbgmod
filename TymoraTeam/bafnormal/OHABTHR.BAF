IF
	ActionListEmpty()
	Allegiance(Myself,ENEMY)
	Class(Myself,BARD_ALL)
	!ModalState(BATTLESONG)
	OR(2)
		See([GOODCUTOFF])
		CombatCounterGT(0)
THEN
	RESPONSE #100
		BattleSong()
END

IF
	Class(Myself,BARD_ALL)
	ModalState(BATTLESONG)
	!GlobalTimerNotExpired("AttackDuringSong","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("AttackDuringSong","LOCALS",TWO_ROUNDS)
		DisplayStringHead(Myself,11798)  // 吟唱歌曲
END

IF
	ActionListEmpty()
	Allegiance(Myself,ENEMY)
	Class(Myself,BARD_ALL)
	ModalState(BATTLESONG)
	!See([GOODCUTOFF])
	CombatCounter(0)
	Delay(30)
THEN
	RESPONSE #100
		ClearActions(Myself)
END

IF
	!HasItem("BLAKBLAD",Myself)  // 毁灭魔剑
	!HasItem("CDGOLIRO",Myself)  // 攻击
	ActionListEmpty()
	Allegiance(Myself,ENEMY)
	GlobalLT("OHABTHRBB","LOCALS",3)
	!GlobalTimerNotExpired("OH_Cast","LOCALS")
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		DisplayStringHead(Myself,46153)  // 使用卷轴
		ForceSpell(Myself,WIZARD_BLACK_BLADE_OF_DISASTER)  // SPWI915.SPL (毁灭魔剑)
		IncrementGlobal("OHABTHRBB","LOCALS",1)
		SetGlobalTimer("OH_Cast","LOCALS",ONE_ROUND)
		SetInterrupt(TRUE)
END

IF
	HasItem("CDGOLIRO",Myself)  // 攻击
	!GlobalTimerNotExpired("OH_Cast","LOCALS")
	GlobalLT("OHABONEPFMW","LOCALS",5)
	Allegiance(Myself,ENEMY)
	AttackedBy([GOODCUTOFF],DEFAULT)
	TookDamage()
	OR(2)
		!CheckSpellState(Myself,PROTECTION_FROM_MAGICAL_WEAPONS)
		!CheckSpellState(Myself,ABSOLUTE_IMMUNITY)
THEN
	RESPONSE #100
		SetGlobalTimer("OH_Cast","LOCALS",ONE_ROUND)
		IncrementGlobal("OHABONEPFMW","LOCALS",1)
		DisplayStringHead(Myself,46153)  // 使用卷轴
		ForceSpell(Myself,WIZARD_ABSOLUTE_IMMUNITY)  // SPWI907.SPL (绝对免疫)
END

