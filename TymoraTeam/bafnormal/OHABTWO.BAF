		SetGlobal("OHABTWOACS","LOCALS",0)
		SetGlobal("OHABTWOWW","LOCALS",0)
		SetGlobal("OHABTWOHARD","LOCALS",0)
		SetGlobal("OHABTWORES","LOCALS",0)
