		SetGlobal("Iapri07","LOCALS",0)
		SetGlobal("Iapri08","LOCALS",0)
		SetGlobal("Iapri09","LOCALS",0)
		SetGlobal("Iapri10","LOCALS",0)
		SetGlobal("Iapri11","LOCALS",0)
		SetGlobal("Iapri17","LOCALS",0)
		SetGlobal("Iapri18","LOCALS",0)
		SetGlobal("Iadispel","LOCALS",0)
		SetGlobal("Iacommand","LOCALS",0)
		SetGlobal("OHABTWOSOV","LOCALS",0)
		SetGlobal("OHABTWOCI","LOCALS",0)
		SetGlobal("OHABTWOR","LOCALS",0)
		SetGlobal("OHABTWOMC","LOCALS",0)
		SetGlobal("OHABTWOCC","LOCALS",0)
		SetGlobal("OHABTWOFA","LOCALS",0)
		SetGlobal("OHABTWOCHANT","LOCALS",0)
