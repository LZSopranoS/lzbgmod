IF
	!GlobalTimerNotExpired("MonkTimer","LOCALS")
	Global("OHABFORLunar","LOCALS",2)
	GlobalLT("OHABFORJFJ","LOCALS",3)
	Range(LastSeenBy(Myself),5)
	!StateCheck(Myself,STATE_HASTED)
	RandomNum(2,1)
THEN
	RESPONSE #100
		SetGlobalTimer("MonkTimer","LOCALS",ONE_ROUND)
		IncrementGlobal("OHABFORJFJ","LOCALS",1)
		ForceSpellRES("SPINI88",Myself)  // 疾风击
		Continue()
END

IF
	!GlobalTimerNotExpired("MonkTimer","LOCALS")
	Global("OHABFORLunar","LOCALS",2)
	GlobalLT("OHABFORJGT","LOCALS",3)
	CheckStatLT(Myself,20,RESISTSLASHING)
	CheckStatLT(Myself,20,RESISTCRUSHING)
	CheckStatLT(Myself,20,RESISTPIERCING)
	AttackedBy([GOODCUTOFF],DEFAULT)
	TookDamage()
THEN
	RESPONSE #100
		SetGlobalTimer("MonkTimer","LOCALS",ONE_ROUND)
		IncrementGlobal("OHABFORJGT","LOCALS",1)
		ForceSpellRES("SPINI87",Myself)  // 金刚体
		Continue()
END

IF
	GlobalLT("OHABFORHD","LOCALS",5)
	!GlobalTimerNotExpired("MonkTimer","LOCALS")
	CheckStatLT(Myself,40,RESISTSLASHING)
	CheckStatLT(Myself,40,RESISTCRUSHING)
	CheckStatLT(Myself,40,RESISTPIERCING)
	AttackedBy([GOODCUTOFF],DEFAULT)
	TookDamage()
THEN
	RESPONSE #100
		IncrementGlobal("OHABFORHD","LOCALS",1)
		SetGlobalTimer("MonkTimer","LOCALS",ONE_ROUND)
		ReallyForceSpell(Myself,WARRIOR_HARDINESS)  // SPCL907.SPL (强韧)
END

IF
	HPPercentLT(Myself,30)
	Global("SecondWind","LOCALS",0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("SecondWind","LOCALS",1)
		DisplayStringHead(Myself,73944)  // 调息！
		ApplySpell(Myself,CLERIC_HEAL)  // SPPR607.SPL (痊愈术)
		SetInterrupt(TRUE)
END

IF
	HPPercentLT(Myself,80)
	!GlobalTimerNotExpired("DrankPotionTimer","LOCALS")
	HasItem("POTN55",Myself)  // 超级强效医疗药水
THEN
	RESPONSE #100
		SetGlobalTimer("DrankPotionTimer","LOCALS",ONE_ROUND)
		DisplayStringHead(Myself,46150)  // 喝下药水
		UseItem("POTN55",Myself)  // 超级强效医疗药水
END

IF
	HitBy([ANYONE],CRUSHING)
	Global("GiantStrengthPotion","LOCALS",0)
	!GlobalTimerNotExpired("DrankPotionTimer","LOCALS")
	HasItem("POTN07",Myself)  // 风暴巨人怪力药水
THEN
	RESPONSE #100
		SetGlobalTimer("DrankPotionTimer","LOCALS",ONE_ROUND)
		SetGlobal("GiantStrengthPotion","LOCALS",1)
		DisplayStringHead(Myself,46150)  // 喝下药水
		UseItem("POTN07",Myself)  // 风暴巨人怪力药水
END

IF
	HPPercentLT(Myself,60)
	!Range(NearestEnemyOf(Myself),5)
	HaveSpell(MONK_LAY_ON_HANDS)  // SPCL815.SPL (圣疗术)
	!GlobalTimerNotExpired("LayOnHands","LOCALS")
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobalTimer("LayOnHands","LOCALS",ONE_ROUND)
		Spell(Myself,MONK_LAY_ON_HANDS)  // SPCL815.SPL (圣疗术)
		SetInterrupt(TRUE)
END

IF
	RandomNum(2,1)
	!GlobalTimerNotExpired("ChangeStance","LOCALS")
	Range(LastSeenBy(Myself),20)
	Global("OHABFORLunar","LOCALS",2)
THEN
	RESPONSE #100
		SetGlobalTimer("ChangeStance","LOCALS",8)
		Shout(SOLAR_STANCE)
		DisplayStringHead(Myself,72906)  // 炎阳势！
		ReallyForceSpellRES("balth01",Myself)  // 炎阳势！
	RESPONSE #100
		SetGlobalTimer("ChangeStance","LOCALS",8)
		DisplayStringHead(Myself,72908)  // 月阴势！
		ReallyForceSpellRES("balth02",Myself)  // 月阴势！
END

IF
	RandomNum(3,1)
	HPPercentLT(Myself,75)
	Range(LastSeenBy(Myself),10)
	Global("OHABFORLunar","LOCALS",2)
	!StateCheck(Myself,STATE_INVISIBLE)
	!StateCheck(Myself,STATE_NORMAL)
	!GlobalTimerNotExpired("ShadowStance","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("ShadowStance","LOCALS",FIVE_ROUNDS)
		DisplayStringHead(Myself,73943)  // 影之姿！
		ReallyForceSpellRES("balth10",Myself)  // 影之姿！
END

IF
	!GlobalTimerNotExpired("MonkTimer","LOCALS")
	Range(LastSeenBy(Myself),4)
	RandomNum(3,1)
	Global("OHABFORLunar","LOCALS",2)
THEN
	RESPONSE #100
		SetGlobalTimer("MonkTimer","LOCALS",3)
		DisplayStringHead(Myself,73942)  // 无影脚！
		FaceObject(LastSeenBy(Myself))
		SwingOnce()
		PlaySound("BALTHA02")
		ReallyForceSpellRES("balth09",LastSeenBy(Myself))  // 无影脚！
END

