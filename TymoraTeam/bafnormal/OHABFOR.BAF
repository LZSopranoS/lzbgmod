IF
	HPPercentLT(Myself,30)
	ActionListEmpty()
	OR(2)
		HasItem("POTN55",Myself)  // 超级强效医疗药水
		HaveSpell(MONK_LAY_ON_HANDS)  // SPCL815.SPL (圣疗术)
	Global("OHABFORLunar","LOCALS",2)
THEN
	RESPONSE #100
		RunAwayFrom(NearestEnemyOf(Myself),45)
END

