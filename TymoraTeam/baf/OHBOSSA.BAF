IF
	GlobalLT("OHBATrapNum","LOCALS",15)
	CheckStatGT(Myself,0,AURACLEANSING)
	CheckStatLT(Myself,50,SPELLFAILUREMAGE)
	!StateCheck(Myself,STATE_SILENCED)
	Allegiance(Myself,ENEMY)
	See([PC])
	!HPLT(LastSeenBy(Myself),50)
	!StateCheck(LastSeenBy(Myself),STATE_CONFUSED)
	!StateCheck(LastSeenBy(Myself),STATE_PANIC)
	!StateCheck(LastSeenBy(Myself),STATE_IMPROVEDINVISIBILITY)
	!StateCheck(LastSeenBy(Myself),STATE_INVISIBLE)
	!CheckStatGT(LastSeenBy(Myself),2,SCRIPTINGSTATE6)
	CheckStat(LastSeenBy(Myself),0,SANCTUARY)
	RandomNum(3,1)
THEN
	RESPONSE #50
		SetInterrupt(FALSE)
		ForceSpell(Myself,WIZARD_IMPROVED_HASTE)  // SPWI613.SPL (高等加速术)
		ForceSpell(Myself,WIZARD_IMPROVED_INVISIBILITY)  // SPWI405.SPL (高等隐形术)
		MoveToObject(LastSeenBy(Myself))
		ForceSpell(Myself,WIZARD_BLINDNESS)  // SPWI106.SPL (目盲)
		ReallyForceSpell(Myself,ROGUE_SET_SPIKE_TRAP)  // SPCL910.SPL (装设尖刺陷阱)
		ForceSpellRangeRES("SPCL910B",LastSeenBy(Myself))  // No such index
		ReallyForceSpell(Myself,ROGUE_SET_EXPLODING_TRAP)  // SPCL911.SPL (装设爆裂陷阱)
		ForceSpellRangeRES("SPCL911B",LastSeenBy(Myself))  // No such index
		ReallyForceSpell(Myself,THIEF_SET_SNARE)  // SPCL412.SPL (装设陷阱)
		ForceSpellRangeRES("SPCL411",LastSeenBy(Myself))  // No such index
		ForceSpell(Myself,CLERIC_CURE_DISEASE)  // SPPR317.SPL (治疗疾病)
		IncrementGlobal("OHBATrapNum","LOCALS",3)
		SetInterrupt(TRUE)
	RESPONSE #50
		SetInterrupt(FALSE)
		ForceSpell(Myself,WIZARD_IMPROVED_HASTE)  // SPWI613.SPL (高等加速术)
		ForceSpell(Myself,WIZARD_IMPROVED_INVISIBILITY)  // SPWI405.SPL (高等隐形术)
		MoveToObject(LastSeenBy(Myself))
		ForceSpell(Myself,WIZARD_BLINDNESS)  // SPWI106.SPL (目盲)
		ReallyForceSpell(Myself,ROGUE_SET_SPIKE_TRAP)  // SPCL910.SPL (装设尖刺陷阱)
		ForceSpellRangeRES("SPCL910B",LastSeenBy(Myself))  // No such index
		ReallyForceSpell(Myself,ROGUE_SET_EXPLODING_TRAP)  // SPCL911.SPL (装设爆裂陷阱)
		ForceSpellRangeRES("SPCL911B",LastSeenBy(Myself))  // No such index
		ReallyForceSpell(Myself,THIEF_SET_SNARE)  // SPCL412.SPL (装设陷阱)
		ForceSpellRangeRES("SPCL411",LastSeenBy(Myself))  // No such index
		ForceSpell(Myself,CLERIC_CURE_DISEASE)  // SPPR317.SPL (治疗疾病)
		IncrementGlobal("OHBATrapNum","LOCALS",3)
		AttackOneRound(LastSeenBy(Myself))
		SetInterrupt(TRUE)
END

