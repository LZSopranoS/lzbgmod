	HasItem("POTN34",Myself)  // 魔法防护药水
	!GlobalTimerNotExpired("Iaspell","LOCALS")
	CheckStatLT(Myself,40,RESISTMAGIC)
	Range(NearestEnemyOf(Myself),30)
THEN
	RESPONSE #100
		SetGlobalTimer("Iaspell","LOCALS",ONE_ROUND)
		UseItem("POTN34",Myself)  // 魔法防护药水
		DisplayStringHead(Myself,46150)  // 喝下药水
