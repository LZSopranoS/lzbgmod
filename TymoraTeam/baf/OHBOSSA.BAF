	!CheckStatGT(LastSeenBy(Myself),0,MINORGLOBE)
	GlobalLT("Iadra07","LOCALS",4)
THEN
	RESPONSE #100
		IncrementGlobal("Iadra07","LOCALS",1)
		SetGlobalTimer("Iaspell","LOCALS",ONE_ROUND)
		SpellNoDec(LastSeenBy(Myself),WIZARD_EMOTION_HOPELESSNESS)  // SPWI411.SPL (情绪控制：绝望)
END

