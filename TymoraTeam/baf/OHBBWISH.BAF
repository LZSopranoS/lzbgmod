IF
	TriggerOverride("OHBOSSB",Global("OHBOSSWish","LOCALS",0))
	TriggerOverride("OHBOSSA",GlobalTimerNotExpired("BOSSAWISHDEALY","LOCALS"))
	TriggerOverride("OHBOSSA",Global("FirstWishDTS","LOCALS",0))
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		IncrementGlobal("WNOTRest","GLOBAL",1)
		ActionOverride("OHBOSSA",SetGlobalTimer("DTSNOCUT","LOCALS",SIX_ROUNDS))
		ActionOverride("OHBOSSB",SetGlobalTimer("DTSNOCUT","LOCALS",SIX_ROUNDS))
		ActionOverride("OHABONE",SetGlobalTimer("DTSNOCUT","LOCALS",SIX_ROUNDS))
		DisplayStringHead("OHBOSSA",72549)  // 在施术者身上施用两倍时效的“时间停止”和“高等迅捷”。
		FaceObject("OHBOSSA")  // 太摩拉双子·金童
		DisplayStringHead(Myself,100278)  // 遵命。
		ActionOverride("OHBOSSA",SetGlobal("OHBOSSAGetDTS","LOCALS",1))
		ActionOverride("OHBOSSA",ReallyForceSpellRES("SPWISH17",Myself))  // 时间停止
		DisplayString("OHBOSSA",63217)  // 高等迅捷
		Wait(1)
		ReallyForceSpell(Myself,POOF_GONE)  // SPIN660.SPL (传送)
		DestroySelf()
		SetInterrupt(TRUE)
END

