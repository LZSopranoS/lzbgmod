/*这段包含EEex_LuaTrigger由solak1.tph替换，涉及两个function MOIsCasting、MoTargetCompare()
IF
	Global("MO_AttackedSomeone","LOCALS",1)
	EEex_LuaTrigger("return MoTargetCompare()")
THEN
	RESPONSE #100
		SetGlobal("MO_AttackedSomeone","LOCALS",0)
		Continue()
END
*/

// EEex - Target Caster (Melee)

IF
	Allegiance(Myself,ENEMY)
	See(LastSeenBy(Myself))
	!Allegiance(LastSeenBy(Myself),ENEMY)
	WeaponEffectiveVs(LastSeenBy(Myself),MAINHAND)
	CheckStatLT(LastSeenBy(Myself),1,SANCTUARY)
	OR(2)
		CheckStatLT(Myself,1,SANCTUARY)
		HPPercentGT(Myself,49)
THEN
	RESPONSE #100
		SetGlobal("MO_AttackedSomeone","LOCALS",1)
		AttackReevaluate(LastSeenBy(Myself),30)
END

IF
	!Allegiance(Myself,ENEMY)
	See(LastSeenBy(Myself))
	Allegiance(LastSeenBy(Myself),ENEMY)
	WeaponEffectiveVs(LastSeenBy(Myself),MAINHAND)
	CheckStatLT(LastSeenBy(Myself),1,SANCTUARY)
	OR(2)
		CheckStatLT(Myself,1,SANCTUARY)
		HPPercentGT(Myself,49)
THEN
	RESPONSE #100
		SetGlobal("MO_AttackedSomeone","LOCALS",1)
		AttackReevaluate(LastSeenBy(Myself),30)
END

IF
	!Detect([GOODCUTOFF])
	Allegiance(Myself,ENEMY)
	OR(2)
		Global("Prep","LOCALS",1)
		HitBy([GOODCUTOFF],CRUSHING)
	!GlobalTimerNotExpired("MO_IsMovingTimer","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("MO_IsMovingTimer","LOCALS",ONE_ROUND)
		MoveToObject(Player1)
END

