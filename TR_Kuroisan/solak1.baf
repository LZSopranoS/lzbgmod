		ApplySpell(Myself,WIZARD_PROTECTION_FROM_MAGIC_WEAPONS)  // SPWI611.SPL (防护魔法武器)
		SetGlobal("Contingency","LOCALS",1)
END

IF
	!CheckSpellState(Myself,AREA_DENIAL)
	Global("MO_AreaDenial","LOCALS",1)
THEN
	RESPONSE #100
		SetGlobal("MO_AreaDenial","LOCALS",0)
		SetGlobal("MO_AreaDenialOnPC","LOCALS",0)
		MoveToOffset([0.0])
		Continue()
END

IF
	!GlobalTimerNotExpired("MO_AreaDenialTimer","LOCALS")
	!Detect([PC])
	CheckSpellState(Myself,AREA_DENIAL)
	Global("MO_AreaDenial","LOCALS",0)
	CheckStatLT(Player1,1,SANCTUARY)
	!StateCheck(Player1,STATE_INVISIBLE)
THEN
	RESPONSE #100
		SetGlobal("MO_AreaDenial","LOCALS",1)
		SetGlobalTimer("MO_AreaDenialTimer","LOCALS",ONE_ROUND)
		MoveToObject(Player1)
END

