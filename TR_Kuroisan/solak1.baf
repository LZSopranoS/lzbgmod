IF
	See(NearestEnemyOfType([PC]))
	Global("Talked","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("Talked","LOCALS",1)
		SetGlobalTimer("TooLong","LOCALS",TWO_HOURS)
		SelectWeaponAbility(SLOT_WEAPON1,0)
		SelectWeaponAbility(SLOT_WEAPON0,0)
		StartDialogueNoSet(NearestEnemyOfType([PC]))
END

IF
	GlobalTimerExpired("TooLong","LOCALS")
	Global("Talked","LOCALS",1)
THEN
	RESPONSE #100
		CreateVisualEffectObject("SPPORTAL",Myself)
		DisplayString(Myself,34746)  // 傲慢的家伙，我诅咒你的灵魂！我不会就这么放过你的！
		SetGlobal("KuroiAlready","GLOBAL",1)
		SetGlobal("KuroiSpawn","GLOBAL",0)
		DestroySelf()
END

IF
	Global("Prep","LOCALS",0)
	See(NearestEnemyOf(Myself))
	DifficultyGT(HARD)
THEN
	RESPONSE #100
		DisplayString(Myself,56010)  // 我打算要摧毁你。
		SetGlobal("Prep","LOCALS",1)
		ReallyForceSpell(Myself,WIZARD_IMPROVED_HASTE)  // SPWI613.SPL (高等加速术)
		ReallyForceSpell(Myself,WIZARD_MIRROR_IMAGE)  // SPWI212.SPL (镜影术)
		ReallyForceSpell(Myself,WIZARD_SPELL_SHIELD)  // SPWI519.SPL (法术护盾)
		ReallyForceSpell(Myself,WIZARD_IMPROVED_MANTLE)  // SPWI808.SPL (高级壁罩术)
		ReallyForceSpell(Myself,WIZARD_BLUR)  // SPWI201.SPL (朦胧术)
		ReallyForceSpell(Myself,WIZARD_RESIST_FEAR)  // SPWI210.SPL (抵抗恐惧)
		ReallyForceSpell(Myself,WIZARD_FIRE_SHIELD_BLUE)  // SPWI403.SPL (火焰盾（蓝）)
		ReallyForceSpell(Myself,WIZARD_PROTECTION_FROM_MAGIC_ENERGY)  // SPWI606.SPL (防护魔法能量)
		// IWD Prebuff
		ReallyForceSpell(Myself,WIZARD_SPELL_IMMUNITY_ABJURATION)  // SPWI590.SPL (法术免疫：防护系)
		SetGlobal("MO_AcidScroll","LOCALS",3)
		CreateCreature("mosol01",[-1.-1],NE)
		CreateCreature("mosol02",[-1.-1],NE)
		CreateCreature("mosol03",[-1.-1],NE)
END

