IF
	!GlobalTimerNotExpired("MO_AreaDenialTimer","LOCALS")
	See([PC])
	CheckSpellState(Myself,AREA_DENIAL)
	!StateCheck(LastSeenBy(Myself),STATE_NOT_APPROACHABLE)
	Global("MO_AreaDenial","LOCALS",0)
	!Range(LastSeenBy(Myself),5)
THEN
	RESPONSE #100
		SetGlobal("MO_AreaDenial","LOCALS",1)
		SetGlobalTimer("MO_AreaDenialTimer","LOCALS",ONE_ROUND)
		MoveToObject(LastSeenBy(Myself))
END

IF
	!GlobalTimerNotExpired("MO_AreaDenialTimer","LOCALS")
	See([PC])
	CheckSpellState(Myself,AREA_DENIAL)
	StateCheck(LastSeenBy(Myself),STATE_NOT_APPROACHABLE)
THEN
	RESPONSE #100
		SetGlobal("MO_AreaDenial","LOCALS",1)
		SetGlobalTimer("MO_AreaDenialTimer","LOCALS",ONE_ROUND)
		RunAwayFromNoLeaveArea(LastSeenBy(Myself),30)
END

IF
	!GlobalTimerNotExpired("MO_AreaDenialTimer","LOCALS")
	See([PC])
	CheckSpellState(Myself,AREA_DENIAL)
	OR(2)
		Range(LastSeenBy(Myself),5)
		Global("MO_AreaDenialOnPC","LOCALS",1)
THEN
	RESPONSE #100
		SetGlobal("MO_AreaDenial","LOCALS",1)
		SetGlobal("MO_AreaDenialOnPC","LOCALS",1)
		SetGlobalTimer("MO_AreaDenialTimer","LOCALS",ONE_ROUND)
		RunAwayFromNoLeaveArea(LastSeenBy(Myself),30)
END

