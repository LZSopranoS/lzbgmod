	See(NearestEnemyOf(Myself))
	LevelGT(LastSeenBy(Myself),15)
	Global("disintegrate","LOCALS",0)
	!GlobalTimerNotExpired("delay","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("delay","LOCALS",ONE_ROUND)
		IncrementGlobal("doomed","LOCALS",1)
		IncrementGlobal("disintegrate","LOCALS",1)
		ReallyForceSpellRES("WM_COW",LastSeenBy(Myself))
		ReallyForceSpell(LastSeenBy(Myself),WIZARD_DISINTEGRATE)  // SPWI616.SPL (解离术)
END

IF
	See(NearestEnemyOf(Myself))
	GlobalLT("assassin","LOCALS",2)
	LevelGT(LastSeenBy(Myself),15)
	Range(LastSeenBy(Myself),4)
THEN
	RESPONSE #100
		SetGlobalTimer("delay","LOCALS",TWO_MINUTES)
		IncrementGlobal("assassin","LOCALS",1)
		SpellRES("SPCL916",Myself)  // 暗杀
		Continue()
END

