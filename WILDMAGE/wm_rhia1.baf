IF
	See(Player1)
	Global("doomed","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("doomed","LOCALS",1)
		StartDialog("WM_RHIA",Player1)
END

IF
	See(NearestEnemyOf(Myself))
	Global("SpellTrigger","LOCALS",0)
	LevelLT(LastSeenBy(Myself),8)
THEN
	RESPONSE #100
		DisplayString(Myself,39968)  // 法术启动－已用出
		ReallyForceSpellRES("WM_LUCK",Myself)
		SetGlobal("SpellTrigger","LOCALS",1)
		ReallyForceSpellRES("WM_LIGHT",Myself)
		ReallyForceSpell(LastSeenBy(Myself),WIZARD_GREATER_MALISON)  // SPWI412.SPL (毒咒)
		ReallyForceSpell(Myself,WIZARD_STONE_SKIN)  // SPWI408.SPL (石肤术)
		ReallyForceSpell(Myself,WIZARD_MIRROR_IMAGE)  // SPWI212.SPL (镜影术)
		ReallyForceSpellRES("WM_ARMOR",Myself)
END

IF
	See(NearestEnemyOf(Myself))
	Global("SpellTrigger","LOCALS",0)
	LevelGT(LastSeenBy(Myself),7)
THEN
	RESPONSE #100
		DisplayString(Myself,39968)  // 法术启动－已用出
		ReallyForceSpellRES("WM_LUCK",Myself)
		SetGlobal("SpellTrigger","LOCALS",1)
		ReallyForceSpellRES("WM_LIGHT",Myself)
		ReallyForceSpell(LastSeenBy(Myself),WIZARD_GREATER_MALISON)  // SPWI412.SPL (毒咒)
		ReallyForceSpellRES("WM_SHLD",Myself)
		ReallyForceSpell(Myself,WIZARD_STONE_SKIN)  // SPWI408.SPL (石肤术)
		ReallyForceSpell(Myself,WIZARD_MIRROR_IMAGE)  // SPWI212.SPL (镜影术)
		ReallyForceSpellRES("WM_ARMOR",Myself)
		ReallyForceSpell(Myself,WIZARD_SPELL_SHIELD)  // SPWI519.SPL (法术护盾)
		ReallyForceSpell(Myself,WIZARD_GLOBE_OF_INVULNERABILITY)  // SPWI602.SPL (法术无效结界)
		ReallyForceSpell(LastSeenBy(Myself),WIZARD_EMOTION_HOPELESSNESS)  // SPWI411.SPL (情绪控制：绝望)
END

IF
	Global("Prep","LOCALS",0)
	See(NearestEnemyOf(Myself))
	TookDamage()
	LevelLT(LastSeenBy(Myself),15)
THEN
	RESPONSE #100
		DisplayString(Myself,40252)  // 意外术－防护魔法武器
		ApplySpell(Myself,WIZARD_PROTECTION_FROM_MAGIC_WEAPONS)  // SPWI611.SPL (防护魔法武器)
		SetGlobal("Prep","LOCALS",1)
END

IF
	Global("Prep","LOCALS",0)
	See(NearestEnemyOf(Myself))
	TookDamage()
	!LevelLT(LastSeenBy(Myself),15)
THEN
	RESPONSE #100
		DisplayString(Myself,43050)  // 连锁意外术－高级壁罩术
		ApplySpell(Myself,WIZARD_IMPROVED_MANTLE)  // SPWI808.SPL (高级壁罩术)
		DisplayString(Myself,3302)  // 连锁意外术－法术反转
		ApplySpell(Myself,WIZARD_SPELL_TURNING)  // SPWI701.SPL (法术反转)
		DisplayString(Myself,40240)  // 连锁意外术－误导术
		ApplySpell(Myself,WIZARD_MISLEAD)  // SPWI607.SPL (误导术)
		SetGlobal("Prep","LOCALS",1)
END

IF
	See([GOODCUTOFF.0.0.0.0.SUMMONED])
	Global("summon","LOCALS",0)
THEN
	RESPONSE #100
		FaceObject(LastSeenBy(Myself))
		Spell(LastSeenBy(Myself),WIZARD_DEATH_SPELL)  // SPWI605.SPL (死亡术)
		SetGlobal("summon","LOCALS",1)
END

IF
	See(NearestEnemyOf(Myself))
	LevelGT(LastSeenBy(Myself),9)
	!HasBounceEffects(Myself)
	!HasImmunityEffects(Myself)
	Global("spell_turning","LOCALS",0)
	!GlobalTimerNotExpired("delay","LOCALS")
THEN
	RESPONSE #100
		SetGlobalTimer("delay","LOCALS",ONE_ROUND)
		IncrementGlobal("spell_turning","LOCALS",1)
		Spell(Myself,WIZARD_SPELL_TURNING)  // SPWI701.SPL (法术反转)
END

