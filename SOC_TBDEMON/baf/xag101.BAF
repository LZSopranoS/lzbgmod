		IncrementGlobal("Iagtwists","XAG101",1)
		SetGlobalTimer("Iapunish","XAG101",THREE_ROUNDS)
		CreateVisualEffect("DDOORH",[1270.900])
		CreateVisualEffect("DDOORH",[1380.830])
		Wait(1)
		CreateCreature("CHALSLAY",[1270.900],W)  // 杀戮者
		CreateCreature("DEMABI01",[1380.830],W)  // 阿比沙魔
	RESPONSE #30
		IncrementGlobal("Iagtwists","XAG101",1)
		SetGlobalTimer("Iapunish","XAG101",THREE_ROUNDS)
		CreateVisualEffect("DDOORH",[1270.900])
		CreateVisualEffect("DDOORH",[1380.830])
		Wait(1)
		CreateCreature("OHBBSLAY",[1270.900],E)  // 杀戮者
		CreateCreature("NWFINGLB",[1380.830],W)
	RESPONSE #40
		IncrementGlobal("Iagtwists","XAG101",1)
		SetGlobalTimer("Iapunish","XAG101",THREE_ROUNDS)
		CreateVisualEffect("DDOORH",[1500.740])
		CreateVisualEffect("DDOORH",[1380.830])
		CreateVisualEffect("DDOORH",[1270.900])
		Wait(1)
		CreateCreature("DEMABI01",[1500.740],W)  // 阿比沙魔
		CreateCreature("NWABISH1",[1380.830],W)
		CreateCreature("NWFINGLB",[1270.900],W)
END

