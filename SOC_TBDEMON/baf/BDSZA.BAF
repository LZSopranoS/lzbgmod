IF
	Global("BDN_TALK","LOCALS",0)
	HPPercentLT(Myself,51)
	InMyArea(Player1)
THEN
	RESPONSE #100
		SetGlobal("BDN_TALK","LOCALS",1)
		ClearAllActions()
		StartCutSceneMode()
		StartCutScene("BDNCUT34")
END

IF
	Global("BDAFTERWISH","LOCALS",0)
	Global("BDN_TALK","LOCALS",1)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("BDAFTERWISH","LOCALS",1)
		DisplayStringHead(Myself,31659)  // 哇哈哈哈！
		ForceSpellRES("SPWI807",Myself)  // 预知术
		ForceSpellRES("SPWI920",Myself)  // 魔能刃
		ForceSpellRES("SPWI405",Myself)  // 高等隐形术
		ForceSpellRES("SPWI592",Myself)  // 法术免疫：预言系
		SetInterrupt(TRUE)
END

IF
	OR(2)
		Global("BDN_TALK","LOCALS",1)
		Global("BDN_TALK","LOCALS",2)
	!HasItem("eneblade",Myself)  // 魔能刃
	!HasItem("CDMINDFL",Myself)  // 攻击
	RandomNum(20,1)
THEN
	RESPONSE #100
		ForceSpellRES("SPWI920",Myself)  // 魔能刃
END

IF
	Global("BDN_TALK","LOCALS",1)
	HPPercentLT(Myself,11)
	InMyArea(Player1)
THEN
	RESPONSE #100
		SetGlobal("BDN_TALK","LOCALS",2)
		ClearAllActions()
		StartCutSceneMode()
		StartCutScene("BDNCUT34")
END

IF
	Global("BDAFTERWISH","LOCALS",1)
	Global("BDN_TALK","LOCALS",2)
	!GlobalTimerNotExpired("MINDFL_TS","LOCALS")
	See([PC])
	!CheckStatGT(LastSeenBy(Myself),0,SCRIPTINGSTATE6)
	CheckStatLT(LastSeenBy(Myself),1,STONESKINS)
	!StateCheck(LastSeenBy(Myself),STATE_MIRRORIMAGE)
	Range(LastSeenBy(Myself),4)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("BDAFTERWISH","LOCALS",2)
		DisplayStringHead(Myself,72979)  // 你死定了！
		ReallyForceSpell(Myself,WIZARD_PROTECTION_FROM_MAGIC_WEAPONS)  // SPWI611.SPL (防护魔法武器)
		ForceSpellRES("spwi613",Myself)  // 高等加速术
		ForceSpellRES("spwi909",Myself)  // 时间停止
		ReallyForceSpell(Myself,SHAPECHANGE_MIND_FLAYER)  // SPIN152.SPL (变形术：夺心魔)
		Polymorph(MINDFLAYER)
		SetGlobalTimer("MINDFL_TS","LOCALS",THREE_ROUNDS)
		SetInterrupt(TRUE)
END

IF
	GlobalTimerNotExpired("MINDFL_TS","LOCALS")
	HasItem("CDMINDFL",Myself)  // 攻击
	See([PC])
	!CheckStatGT(LastSeenBy(Myself),0,SCRIPTINGSTATE6)
	CheckStatLT(LastSeenBy(Myself),1,STONESKINS)
	!StateCheck(LastSeenBy(Myself),STATE_MIRRORIMAGE)
THEN
	RESPONSE #100
		AttackOneRound(LastSeenBy(Myself))
END

