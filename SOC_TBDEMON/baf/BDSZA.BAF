	HasItem("WAND18",Myself)  // 法术重击之杖
	GlobalLT("BD_PierceW","LOCALS",6)
	See([PC])
	!StateCheck(LastSeenBy(Myself),STATE_REALLY_DEAD)
	OR(4)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY2)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY15)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY9)
		CheckStatGT(LastSeenBy(Myself),0,SCRIPTINGSTATE7)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
		IncrementGlobal("BD_PierceW","LOCALS",1)
		DisplayStringHead(Myself,31971)  // 使用一柄法杖
		ReallyForceSpell(LastSeenBy(Myself),WIZARD_PIERCE_MAGIC)  // SPWI608.SPL (识破魔法)
		SetInterrupt(TRUE)
END

