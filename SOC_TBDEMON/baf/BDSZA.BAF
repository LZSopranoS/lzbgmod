		ReallyForceSpell(Myself,WIZARD_STONE_SKIN)  // SPWI408.SPL (石肤术)
		ReallyForceSpell(Myself,WIZARD_FIRE_SHIELD_RED)  // SPWI418.SPL (火焰护盾（红）)
		ReallyForceSpell(Myself,WIZARD_FIRE_SHIELD_BLUE)  // SPWI403.SPL (火焰盾（蓝）)
END

IF
	GlobalGT("BDN_TALK","LOCALS",1)
	Global("BDN_REFRESH","LOCALS",0)
	!HaveSpell(WIZARD_TIME_STOP)  // SPWI909.SPL (时间停止)
	!HaveSpell(WIZARD_IMPROVED_ALUCRITY)  // SPWI921.SPL (高等迅捷)
	!GlobalTimerNotExpired("BD_Cast","LOCALS")
	GlobalLT("BDNSTWish","LOCALS",3)
	!CheckStatGT(Myself,0,AURACLEANSING)
	!HasItem("CDMINDFL",Myself)  // 攻击
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		IncrementGlobal("BDNSTWish","LOCALS",1)
		SetGlobal("BDN_REFRESH","LOCALS",1)
		SetGlobal("BDNWish","GLOBAL",1)
		SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
		DisplayStringHead(Myself,100275)  // 摇一个铃
		ForceSpellRES("BDNWISH",Myself)  // 愿望术
		SetGlobal("BD_CHCntg","LOCALS",0)
		SetGlobal("BD_Cntg","LOCALS",0)
		SetGlobal("BD_Seq","LOCALS",0)
		SetGlobal("BD_MSeq","LOCALS",0)
		SetGlobal("BD_Trig","LOCALS",0)
		Wait(1)
		SetInterrupt(TRUE)
END

