IF
	!GlobalTimerNotExpired("BD_Cast","LOCALS")
	!GlobalTimerNotExpired("BD_TStop","LOCALS")
	HasItem("WAND18",Myself)  // 法术重击之杖
	GlobalLT("BD_BreachW","LOCALS",6)
	!GlobalTimerNotExpired("BD_BREACH","LOCALS")
	See([PC])
	OR(4)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY14)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY5)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY12)
		CheckStatGT(LastSeenBy(Myself),0,STONESKINS)
	!StateCheck(LastSeenBy(Myself),STATE_REALLY_DEAD)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		IncrementGlobal("BD_BreachW","LOCALS",1)
		SetGlobalTimer("BD_BREACH","LOCALS",TWO_ROUNDS)
		SetGlobalTimer("BD_Cast","LOCALS",ONE_ROUND)
		DisplayStringHead(Myself,31971)  // 使用一柄法杖
		UseItem("WAND18",LastSeenBy(Myself))  // 法术重击之杖
		SetInterrupt(TRUE)
END

