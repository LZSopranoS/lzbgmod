		StateCheck(LastSeenBy(Myself),STATE_MIRRORIMAGE)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY4)
		CheckStatGT(LastSeenBy(Myself),0,STONESKINS)
		CheckSpellState(LastSeenBy(Myself),RESIST_FEAR)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY19)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY5)
		CheckStatGT(LastSeenBy(Myself),0,EXTRAPROFICIENCY17)
