IF
	!GlobalTimerNotExpired("MINDFL_TS","LOCALS")
	HasItem("CDMINDFL",Myself)  // 攻击
THEN
	RESPONSE #100
		ReallyForceSpell(Myself,SHAPESHIFT_NATURAL_FORM_2)  // SPIN151.SPL (变回原来形态)
		Polymorph(MEFISTO_ACIFER)
END

IF
	Global("BDN_TALK","LOCALS",2)
	!HasItem("CDMINDFL",Myself)  // 攻击
	Dead("BDSHANG")  // 三体恶魔·贪婪
	Dead("BDLAYEN")  // 三体恶魔·狡诈
	HPPercentLT(Myself,11)
	InMyArea(Player1)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("BDN_TALK","LOCALS",3)
		DisplayStringHead(Myself,11131)  // 我要杀了你！
		ReallyForceSpell(Myself,RESTORE_FULL_HEALTH)  // SPIN746.SPL (No such index)
		ForceSpellRES("SPWI405",Myself)  // 高等隐形术
		ForceSpellRES("OHBBCLT3",Myself)  // 掠夺者改变
		Wait(1)
		ChangeAnimationNoEffect("OHBBRVG2")  // 掠夺者
		SetInterrupt(TRUE)
END

IF
	Global("BD_Active","LOCALS",0)
	OR(3)
		AttackedBy([ANYONE],DEFAULT)
		TookDamage()
		Allegiance(Myself,ENEMY)
THEN
	RESPONSE #100
		SetGlobal("BD_Active","LOCALS",1)
		SetGlobalTimer("BD_Rest","LOCALS",ONE_HOUR)
		Continue()
END

IF
	OR(4)
		Global("BD_Active","LOCALS",0)
		!Allegiance(Myself,EVILCUTOFF)
		StateCheck(Myself,STATE_IMMOBILE)
		StateCheck(Myself,STATE_REALLY_DEAD)
THEN
	RESPONSE #100
		NoAction()
END

IF
	!GlobalTimerNotExpired("BD_Rest","LOCALS")
	!HasItem("CDMINDFL",Myself)  // 攻击
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobalTimer("BD_Rest","LOCALS",ONE_HOUR)
		SetGlobal("BD_CHCntg","LOCALS",0)
		SetGlobal("BD_Cntg","LOCALS",0)
		SetGlobal("BD_Seq","LOCALS",0)
		SetGlobal("BD_MSeq","LOCALS",0)
		SetGlobal("BD_Trig","LOCALS",0)
		ApplySpell(Myself,RESTORE_FULL_HEALTH)  // SPIN746.SPL (No such index)
		Rest()
		SetInterrupt(TRUE)
END

IF
	Global("BD_Active","LOCALS",1)
	Global("BD_CHCntg","LOCALS",0)
	See(NearestEnemyOf(Myself))
	!StateCheck(Myself,STATE_REALLY_DEAD)
THEN
	RESPONSE #100
		SetGlobal("BD_CHCntg","LOCALS",1)
		DisplayString(Myself,26328)  // 连锁意外术
		ReallyForceSpell(Myself,WIZARD_PROTECTION_FROM_ENERGY)  // SPWI803.SPL (防护能量)
		ReallyForceSpell(Myself,WIZARD_PROTECTION_FROM_MAGIC_WEAPONS)  // SPWI611.SPL (防护魔法武器)
		ReallyForceSpell(Myself,WIZARD_SPELL_TURNING)  // SPWI701.SPL (法术反转)
		Continue()
END

IF
