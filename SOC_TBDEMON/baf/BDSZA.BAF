	!StateCheck(Myself,STATE_SILENCED)
	!CheckStatGT(Myself,0,EXTRAPROFICIENCY14)
	CheckStatLT(Myself,1,STONESKINS)
	CheckStat(Myself,0,EXTRAPROFICIENCY11)
	Range([GOODCUTOFF],30)
THEN
	RESPONSE #100
