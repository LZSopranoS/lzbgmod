IF
	Allegiance(Myself,ENEMY)
	ActionListEmpty()
	HPPercentLT(Myself,50)
	!HPLT(Myself,1)
	See([PC])
	CheckStatLT(LastSeenBy(Myself),100,MAGICDAMAGERESISTANCE)
	CheckStatLT(LastSeenBy(Myself),50,RESISTMAGIC)
	Global("Iacontingency","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("Iacontingency","LOCALS",1)
		DisplayString(Myself,26328)  // 连锁意外术
		ReallyForceSpell(LastSeenBy(Myself),WIZARD_ABI_DALZIMS_HORRID_WILTING)  // SPWI812.SPL (亚比达奇凋死术)
		ReallyForceSpell(LastSeenBy(Myself),WIZARD_ABI_DALZIMS_HORRID_WILTING)  // SPWI812.SPL (亚比达奇凋死术)
		ReallyForceSpell(LastSeenBy(Myself),WIZARD_ABI_DALZIMS_HORRID_WILTING)  // SPWI812.SPL (亚比达奇凋死术)
END

IF
	HPPercentLT(Myself,41)
	Global("BDSHANG_SC","LOCALS",0)
THEN
	RESPONSE #100
		SetInterrupt(FALSE)
		SetGlobal("BDSHANG_SC","LOCALS",1)
		ReallyForceSpell(Myself,RESTORE_FULL_HEALTH)  // SPIN746.SPL (No such index)
		ReallyForceSpell(Myself,WIZARD_PROTECTION_FROM_MAGIC_WEAPONS)  // SPWI611.SPL (防护魔法武器)
		ReallyForceSpell(Myself,SHAPECHANGE_IRON_GOLEM)  // SPIN153.SPL (变形术：铁魔像)
		Polymorph(GOLEM_IRON)
		SetGlobalTimer("IRONGOLEM_TS","LOCALS",ONE_HOUR)
		SetInterrupt(TRUE)
END

IF
	!GlobalTimerNotExpired("BD_AttackBuffTimer","LOCALS")
	GlobalLT("BDSHANG_WW","LOCALS",6)
	HasItem("CDGOLIRO",Myself)  // 攻击
	See([PC])
	WeaponEffectiveVs(LastSeenBy(Myself),MAINHAND)
	Range(LastSeenBy(Myself),5)
THEN
	RESPONSE #100
		IncrementGlobal("BDSHANG_WW","LOCALS",1)
		SetGlobalTimer("BD_AttackBuffTimer","LOCALS",ONE_ROUND)
		ReallyForceSpell(Myself,WARRIOR_GREATER_WHIRLWIND)  // SPCL901.SPL (强力旋风攻击)
END

IF
	HPPercentLT(Myself,71)
	!GlobalTimerNotExpired("BD_AttackBuffTimer","LOCALS")
	GlobalLT("BDSHANG_HD","LOCALS",3)
	HasItem("CDGOLIRO",Myself)  // 攻击
	CheckStatLT(Myself,71,RESISTSLASHING)
	CheckStatLT(Myself,71,RESISTCRUSHING)
	CheckStatLT(Myself,71,RESISTPIERCING)
	AttackedBy([GOODCUTOFF],DEFAULT)
	TookDamage()
THEN
	RESPONSE #100
		IncrementGlobal("BDSHANG_HD","LOCALS",1)
		SetGlobalTimer("BD_AttackBuffTimer","LOCALS",ONE_ROUND)
		ReallyForceSpell(Myself,WARRIOR_HARDINESS)  // SPCL907.SPL (强韧)
END

