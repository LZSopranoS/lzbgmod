IF
	Allegiance(Myself,ENEMY)
	!GlobalTimerNotExpired("Iauseitem","LOCALS")
	!GlobalTimerNotExpired("Iawishcombo","LOCALS")
	See(Player1)
	!StateCheck(Player1,STATE_NOT_TARGETABLE)
	CheckStatLT(Player1,30,RESISTMAGIC)
	!CheckStat(Player1,2,WIZARD_SPELL_IMMUNITY)
	!CheckStatGT(Player1,0,DEATH_WARD)
	!HasBounceEffects(Player1)
	HPLT(Player1,60)
	Global("Iapwkill","LOCALS",0)
THEN
	RESPONSE #100
		SetGlobal("Iapwkill","LOCALS",1)
		SetGlobalTimer("Iauseitem","LOCALS",ONE_ROUND)
		SpellNoDec(Player1,WIZARD_POWER_WORD_KILL)  // SPWI912.SPL (律令：死亡)
END

IF
	Global("Ialayene07","LOCALS",1)
	HasItem("eneblade",Myself)  // 魔能刃
	ActionListEmpty()
	See(Player1)
	WeaponEffectiveVs(Player1,MAINHAND)
THEN
	RESPONSE #100
		AttackOneRound(Player1)
END

