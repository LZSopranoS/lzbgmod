IF
	Allegiance(Myself,ENEMY)
	!GlobalTimerNotExpired("Iauseitem","LOCALS")
	!GlobalTimerNotExpired("Iawishcombo","LOCALS")
	OR(2)
		!GlobalTimerNotExpired("absolute","LOCALS")
		CheckStat(Myself,0,WIZARD_PROTECTION_FROM_MAGIC_WEAPONS)
	!CheckStatGT(Myself,0,AURACLEANSING)
	See(NearestEnemyOf(Myself))
	GlobalLT("Ialayene27","LOCALS",9)
	HasItem("scrl9p",Myself)  // 绝对免疫
THEN
	RESPONSE #100
		SetGlobalTimer("absolute","LOCALS",FOUR_ROUNDS)
		SetGlobalTimer("Iauseitem","LOCALS",ONE_ROUND)
		IncrementGlobal("Ialayene27","LOCALS",1)
		DisplayStringHead(Myself,46153)  // 使用卷轴
		UseItem("scrl9p",Myself)  // 绝对免疫
		EquipMostDamagingMelee()
END

