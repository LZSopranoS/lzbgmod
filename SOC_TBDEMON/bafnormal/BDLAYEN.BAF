IF
	Allegiance(Myself,ENEMY)
	!StateCheck(Myself,STATE_DISABLED_CASTING)
	!GlobalTimerNotExpired("Iauseitem","LOCALS")
	!GlobalTimerNotExpired("Iaexrm","LOCALS")
	!GlobalTimerNotExpired("Iawishcombo","LOCALS")
	OR(2)
		!GlobalTimerNotExpired("Ialayenets","XAG101")
		Global("Ialayene07","LOCALS",0)
	See(Player1)
	!StateCheck(Player1,STATE_DISABLED)
	OR(2)
	    StateCheck(Player1,STATE_MIRRORIMAGE)
	    StateCheck(Player1,STATE_IMPROVEDINVISIBILITY)
	!CheckStat(Player1,1,WIZARD_SPELL_IMMUNITY)
THEN
	RESPONSE #100
		SetGlobalTimer("Iaexrm","LOCALS",FOUR_ROUNDS)
		SetGlobalTimer("Iauseitem","LOCALS",ONE_ROUND)
		ForceSpell(Player1,WIZARD_REMOVE_MAGIC)  // SPWI302.SPL (移除魔法)
		EquipMostDamagingMelee()
END

IF
	Allegiance(Myself,ENEMY)
	Global("Iaspellstrike","LOCALS",0)
	!GlobalTimerNotExpired("Iauseitem","LOCALS")
	!GlobalTimerNotExpired("Iawishcombo","LOCALS")
	See(Player1)
	!StateCheck(LastSeenBy(Myself),STATE_NOT_TARGETABLE)
    !CheckStat(LastSeenBy(Myself),1,WIZARD_SPELL_IMMUNITY)
	OR(2)
		HasBounceEffects(LastSeenBy(Myself))
		HasImmunityEffects(LastSeenBy(Myself))
	!StateCheck(Myself,STATE_DISABLED_CASTING)
	HasItem("scrl9m",Myself)
THEN
	RESPONSE #100
		SetGlobal("Iaspellstrike","LOCALS",1)
		SetGlobalTimer("Iauseitem","LOCALS",ONE_ROUND)
		DestroyItem("scrl9m")  // 法术重击
		DisplayStringHead(Myself,46153)  // 使用卷轴
		ForceSpell(Player1,WIZARD_SPELL_STRIKE)  // SPWI903.SPL (法术重击)
		EquipMostDamagingMelee()
END

IF
	Allegiance(Myself,ENEMY)
	GlobalLT("Iareversal","LOCALS",6)
	!GlobalTimerNotExpired("Iauseitem","LOCALS")
	!GlobalTimerNotExpired("Iawishcombo","LOCALS")
	See(Player1)
	!StateCheck(LastSeenBy(Myself),STATE_NOT_TARGETABLE)
	!CheckStat(LastSeenBy(Myself),8,WIZARD_SPELL_IMMUNITY)
	OR(6)
		CheckStatGT(LastSeenBy(Myself),0,WIZARD_SPELL_DEFLECTION)
		CheckStatGT(LastSeenBy(Myself),0,WIZARD_SPELL_TURNING)
		CheckStatGT(LastSeenBy(Myself),0,CLERIC_SHIELD_OF_THE_ARCHONS)
		CheckStatGT(LastSeenBy(Myself),0,WIZARD_SPELL_IMMUNITY)
		CheckStatGT(LastSeenBy(Myself),0,WIZARD_SPELL_TRAP)
		CheckStatGT(LastSeenBy(Myself),0,MINORGLOBE)
THEN
	RESPONSE #100
		IncrementGlobal("Iareversal","LOCALS",1)
		SetGlobalTimer("Iauseitem","LOCALS",ONE_ROUND)
		SpellNoDec(Player1,WIZARD_RUBY_RAY_OF_REVERSAL)  // SPWI704.SPL (红宝石逆转射线)
		EquipMostDamagingMelee()
END

IF
	Allegiance(Myself,ENEMY)
	GlobalLT("Iacastbreach","LOCALS",5)
	!GlobalTimerNotExpired("Iauseitem","LOCALS")
	!GlobalTimerNotExpired("Iawishcombo","LOCALS")
	OR(2)
		!GlobalTimerNotExpired("Ialayenets","XAG101")
		Global("Ialayene07","LOCALS",0)
	See(Player1)
	!StateCheck(LastSeenBy(Myself),STATE_NOT_TARGETABLE)
	!CheckStat(LastSeenBy(Myself),1,WIZARD_SPELL_IMMUNITY)
	!CheckSpellState(LastSeenBy(Myself),SPELL_SHIELD)
	OR(7)
		CheckSpellState(LastSeenBy(Myself),PROTECTION_FROM_MAGICAL_WEAPONS)
		CheckSpellState(LastSeenBy(Myself),MANTLE)
		CheckSpellState(LastSeenBy(Myself),IMPROVED_MANTLE)
